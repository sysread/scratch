#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# coordinator agent - standalone mode
#
# For standalone invocations via agent:run (not the chat loop). Reads a
# JSON messages array from stdin, runs agent:complete, returns text.
# The chat loop uses agent:complete directly for multi-turn support.
#
# stdin:  JSON array of message objects
# stdout: the assistant's response text
#-------------------------------------------------------------------------------

set -euo pipefail

# shellcheck source=/dev/null
source "$SCRATCH_HOME/lib/agent.sh"

# In standalone mode, stdin is the full messages array (not a single
# string). Read it and pass to agent:complete directly.
# shellcheck disable=SC2034
messages="$(cat)"
response=""
agent:complete coordinator messages response
printf '%s' "$response"
