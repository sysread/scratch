#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# intuition agent - reference implementation of a complex multi-phase agent
#
# Adapted from fnord's AI.Agent.Intuition (~370 lines of Elixir, 10 drives).
# This bash version is structurally identical but smaller for cost reasons:
# 4 drives instead of 10, smaller prompts, same three phases.
#
# Phase 1: Perception
#   Read the transcript on stdin (potentially huge - chat history with
#   tool call results, code, etc.) and reduce it via the accumulator
#   into a structured perception of the situation. Uses the long-context
#   profile (qwen-3-6-plus) so we have the largest possible window for
#   the chunking.
#
# Phase 2: Drive reactions (parallel)
#   For each drive prompt under data/prompts/intuition/drives/, run a
#   chat:completion against the perception with that drive's specific
#   system prompt. All drives run in parallel via workers:run-parallel.
#   Uses the fast profile because the drive prompts are short and we
#   want low latency for the fan-out.
#
# Phase 3: Synthesis
#   Concatenate the drive reactions and run a single chat:completion
#   that synthesizes them into a coherent first-person directive.
#   Uses the smart profile - this is the highest-quality decision
#   point in the workflow.
#
# stdout: the synthesized intuition (plain text, ~1 paragraph)
# stderr: progress logs via tui:info
#-------------------------------------------------------------------------------

set -euo pipefail

# shellcheck source=/dev/null
{
  source "$SCRATCH_HOME/lib/base.sh"
  source "$SCRATCH_HOME/lib/tempfiles.sh"
  source "$SCRATCH_HOME/lib/prompt.sh"
  source "$SCRATCH_HOME/lib/chat.sh"
  source "$SCRATCH_HOME/lib/accumulator.sh"
  source "$SCRATCH_HOME/lib/workers.sh"
  source "$SCRATCH_HOME/lib/model.sh"
  source "$SCRATCH_HOME/lib/tui.sh"
}

# ---------------------------------------------------------------------------
# Phase 1: perception via accumulator
# ---------------------------------------------------------------------------

tui:info "intuition: phase 1 - perception"
transcript="$(cat)"

# A genuinely empty transcript breaks the accumulator's reduce loop and
# leaves the model with nothing to react to. Bail out early with a
# clear message rather than spending API calls on noise.
if [[ -z "$transcript" ]]; then
  die "intuition: empty transcript on stdin"
  exit 1
fi

perception="$(
  accumulate:run-profile long-context \
    "$(prompt:load intuition/perception)" \
    "$transcript" \
    '{"question":"Respond with your subconscious perception."}'
)"

# ---------------------------------------------------------------------------
# Phase 2: parallel drive reactions
# ---------------------------------------------------------------------------

tui:info "intuition: phase 2 - drive reactions"

# The set of drives the agent considers. Order does not matter; the
# synthesis pass concatenates results regardless. To add a drive: drop
# a file under data/prompts/intuition/drives/<name>.md and add the
# name here.
DRIVES=(curiosity skepticism pragmatism stewardship)

# Pre-allocate the workdir in the parent shell so tmp:track's registry
# records it. Workers index into the parent arrays directly.
DRIVE_WORKDIR="$(mktemp -d -t scratch-intuition.XXXXXX)"
tmp:track "$DRIVE_WORKDIR"
tmp:install-traps

PERCEPTION="$perception"
DRIVE_BASE="$(prompt:load intuition/drive-base)"
DRIVE_MODEL="$(model:profile:model fast)"
DRIVE_EXTRAS="$(model:profile:extras fast)"
export DRIVES PERCEPTION DRIVE_BASE DRIVE_MODEL DRIVE_EXTRAS DRIVE_WORKDIR

# Worker function: looks up its drive name from DRIVES[i], loads the
# drive's specific prompt, builds the messages, calls chat:completion,
# extracts the content, and writes it to a per-index file in the workdir.
# shellcheck disable=SC2329 # invoked indirectly by workers:run-parallel
_intuition_drive_worker() {
  local i="$1"
  local drive="${DRIVES[i]}"
  local drive_prompt
  drive_prompt="$(prompt:load "intuition/drives/${drive}")"

  local system_prompt="${DRIVE_BASE}"$'\n\n'"${drive_prompt}"
  local user_msg="# My perception of the discussion:"$'\n'"${PERCEPTION}"

  local messages
  messages="$(
    jq -c -n \
      --arg s "$system_prompt" \
      --arg u "$user_msg" \
      '[{role:"system",content:$s},{role:"user",content:$u}]'
  )"

  chat:completion "$DRIVE_MODEL" "$messages" "$DRIVE_EXTRAS" \
    | chat:extract-content \
    > "${DRIVE_WORKDIR}/${i}.out"
}
export -f _intuition_drive_worker

workers:run-parallel \
  "${SCRATCH_INTUITION_PARALLEL_JOBS:-$(workers:cpu-count)}" \
  "${#DRIVES[@]}" \
  _intuition_drive_worker

# ---------------------------------------------------------------------------
# Phase 3: synthesis
# ---------------------------------------------------------------------------

tui:info "intuition: phase 3 - synthesis"

# Concatenate the reactions in input order. The synthesis prompt does
# not need to know which drive said what; it just needs the union of
# their reactions.
reactions=""
for ((i = 0; i < ${#DRIVES[@]}; i++)); do
  reactions+="$(cat "${DRIVE_WORKDIR}/${i}.out")"$'\n\n'
done

synthesis_system="$(prompt:load intuition/synthesis)"
perception_msg="# Perception"$'\n'"${perception}"

synthesis_messages="$(
  jq -c -n \
    --arg s "$synthesis_system" \
    --arg p "$perception_msg" \
    --arg r "$reactions" \
    '[
      {role:"system",   content:$s},
      {role:"user",     content:$p},
      {role:"assistant",content:$r}
    ]'
)"

synthesis_model="$(model:profile:model smart)"
synthesis_extras="$(model:profile:extras smart)"
chat:completion "$synthesis_model" "$synthesis_messages" "$synthesis_extras" \
  | chat:extract-content
