#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# intuition agent - reference implementation of a multi-phase agent
#
# Adapted from fnord's AI.Agent.Intuition (~370 lines of Elixir, 10 drives).
# This bash version is structurally identical but smaller for cost reasons:
# 4 drives instead of 10, smaller prompts, same three phases.
#
# All three phases use the `fast` profile with venice_parameters.disable_thinking
# enabled, because the intuition workflow values low latency over reasoning
# depth - the value comes from running multiple distinct lenses in parallel,
# not from any single phase being a deep thinker. The fan-out is the
# reasoning, in aggregate.
#
# Phase 1: Perception
#   Read the transcript on stdin and run a single completion to summarize
#   the situation. A typical chat transcript fits in the fast model's
#   context window, so this phase is a single chat:completion rather than
#   a chunked accumulator pass.
#
# Phase 2: Drive reactions (parallel)
#   For each drive prompt under data/prompts/intuition/drives/, run a
#   chat:completion against the perception with that drive's specific
#   system prompt. All drives run in parallel via workers:run-parallel.
#
# Phase 3: Synthesis
#   Concatenate the drive reactions and run a single chat:completion
#   that synthesizes them into a coherent first-person directive.
#
# stdout: the synthesized intuition (plain text, ~1 paragraph)
# stderr: empty by default; debug output when SCRATCH_DEBUG_INTUITION is set
#
# Debugging:
#   SCRATCH_DEBUG_INTUITION=1  Logs each phase's full output to stderr,
#                              labeled (perception, drive:<name>, synthesis)
#                              via tui:info.
#-------------------------------------------------------------------------------

set -euo pipefail

# shellcheck source=/dev/null
{
  source "$SCRATCH_HOME/lib/base.sh"
  source "$SCRATCH_HOME/lib/tempfiles.sh"
  source "$SCRATCH_HOME/lib/prompt.sh"
  source "$SCRATCH_HOME/lib/chat.sh"
  source "$SCRATCH_HOME/lib/workers.sh"
  source "$SCRATCH_HOME/lib/model.sh"
  source "$SCRATCH_HOME/lib/tui.sh"
}

# Debug helper. When SCRATCH_DEBUG_INTUITION is set (any value), log a
# label and a content payload to stderr via tui:info. When the debug
# flag is unset this is a no-op.
#
# Exported because the drive reaction worker (which runs in a subshell
# under workers:run-parallel) calls it.
# shellcheck disable=SC2329 # invoked from the main script and from worker subshells
_intuition_debug() {
  [[ -n "${SCRATCH_DEBUG_INTUITION:-}" ]] || return 0
  local label="$1"
  local content="$2"
  tui:info "intuition[${label}]" content "$content"
}
export -f _intuition_debug

# Resolve the model + extras once. Every chat call in this agent uses
# the fast profile with disable_thinking layered on top, since the
# whole agent is optimized for fan-out latency rather than per-call
# reasoning depth.
INTUITION_MODEL="$(model:profile:model fast)"
INTUITION_EXTRAS="$(
  model:profile:extras fast |
    jq -c '. + {venice_parameters: ((.venice_parameters // {}) + {disable_thinking: true})}'
)"
export INTUITION_MODEL INTUITION_EXTRAS

# ---------------------------------------------------------------------------
# Phase 1: perception (single completion, no accumulator)
# ---------------------------------------------------------------------------

transcript="$(cat)"

if [[ -z "$transcript" ]]; then
  die "intuition: empty transcript on stdin"
  exit 1
fi

perception_system="$(prompt:load intuition/perception)"
perception_messages="$(
  jq -c -n \
    --arg s "$perception_system" \
    --arg u "$transcript" \
    '[{role:"system",content:$s},{role:"user",content:$u}]'
)"

perception="$(
  chat:completion "$INTUITION_MODEL" "$perception_messages" "$INTUITION_EXTRAS" |
    chat:extract-content
)"

_intuition_debug perception "$perception"

# ---------------------------------------------------------------------------
# Phase 2: parallel drive reactions
# ---------------------------------------------------------------------------

# The set of drives the agent considers. Order does not matter; the
# synthesis pass concatenates results regardless. To add a drive: drop
# a file under data/prompts/intuition/drives/<name>.md and add the
# name here.
DRIVES=(curiosity skepticism pragmatism stewardship)

# Pre-allocate the workdir in the parent shell so tmp:track's registry
# records it. Workers index into the parent arrays directly.
DRIVE_WORKDIR="$(mktemp -d -t scratch-intuition.XXXXXX)"
tmp:track "$DRIVE_WORKDIR"
tmp:install-traps

PERCEPTION="$perception"
DRIVE_BASE="$(prompt:load intuition/drive-base)"
export DRIVES PERCEPTION DRIVE_BASE DRIVE_WORKDIR

# Worker function: looks up its drive name from DRIVES[i], loads the
# drive's specific prompt, builds the messages, calls chat:completion,
# extracts the content, and writes it to a per-index file in the workdir.
# shellcheck disable=SC2329 # invoked indirectly by workers:run-parallel
_intuition_drive_worker() {
  local i="$1"
  local drive="${DRIVES[i]}"
  local drive_prompt
  drive_prompt="$(prompt:load "intuition/drives/${drive}")"

  local system_prompt="${DRIVE_BASE}"$'\n\n'"${drive_prompt}"
  local user_msg="# My perception of the discussion:"$'\n'"${PERCEPTION}"

  local messages
  messages="$(
    jq -c -n \
      --arg s "$system_prompt" \
      --arg u "$user_msg" \
      '[{role:"system",content:$s},{role:"user",content:$u}]'
  )"

  chat:completion "$INTUITION_MODEL" "$messages" "$INTUITION_EXTRAS" |
    chat:extract-content \
      >"${DRIVE_WORKDIR}/${i}.out"

  _intuition_debug "drive:${drive}" "$(cat "${DRIVE_WORKDIR}/${i}.out")"
}
export -f _intuition_drive_worker

workers:run-parallel \
  "${SCRATCH_INTUITION_PARALLEL_JOBS:-$(workers:cpu-count)}" \
  "${#DRIVES[@]}" \
  _intuition_drive_worker

# ---------------------------------------------------------------------------
# Phase 3: synthesis
# ---------------------------------------------------------------------------

# Concatenate the reactions in input order. The synthesis prompt does
# not need to know which drive said what; it just needs the union of
# their reactions.
reactions=""
for ((i = 0; i < ${#DRIVES[@]}; i++)); do
  reactions+="$(cat "${DRIVE_WORKDIR}/${i}.out")"$'\n\n'
done

synthesis_system="$(prompt:load intuition/synthesis)"
perception_msg="# Perception"$'\n'"${perception}"

synthesis_messages="$(
  jq -c -n \
    --arg s "$synthesis_system" \
    --arg p "$perception_msg" \
    --arg r "$reactions" \
    '[
      {role:"system",   content:$s},
      {role:"user",     content:$p},
      {role:"assistant",content:$r}
    ]'
)"

synthesis="$(
  chat:completion "$INTUITION_MODEL" "$synthesis_messages" "$INTUITION_EXTRAS" |
    chat:extract-content
)"

_intuition_debug synthesis "$synthesis"

printf '%s\n' "$synthesis"
