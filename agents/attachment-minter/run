#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# attachment-minter agent - confirm a cluster and mint an attachment
#
# stdin: JSON object {
#   "sample_labels": ["...", "...", "..."],   # relation labels from cluster
#   "sample_situations": ["...", "..."],       # substrate situation excerpts
#   "count": N,                                # total associations in cluster
#   "total_reinforcement": N                   # sum of reinforcement
# }
#
# stdout: JSON object {
#   "confirm": true | false,
#   "prediction": "<short, third-person tendency>",
#   "inner_voice": "<short self-talk>",
#   "affect": "<one of the 8 controlled tags>",
#   "confidence": 0.0..1.0
# }
#
# If confirm is false, the other fields may be absent or empty — the
# caller discards the cluster.
#
# Controlled affect vocabulary:
#   wary, curious, confident, uneasy, resigned, eager, uncertain, surprised
#
# Malformed JSON from the model falls back to {"confirm": false}; the
# consolidation pipeline treats that as "skip this cluster, try again
# next pass".
#-------------------------------------------------------------------------------

set -euo pipefail

# shellcheck source=/dev/null
{
  source "$SCRATCH_HOME/lib/base.sh"
  source "$SCRATCH_HOME/lib/prompt.sh"
  source "$SCRATCH_HOME/lib/chat.sh"
  source "$SCRATCH_HOME/lib/model.sh"
}

MINTER_MODEL="$(model:profile:model fast)"
MINTER_EXTRAS="$(
  model:profile:extras fast |
    jq -c '. + {venice_parameters: ((.venice_parameters // {}) + {disable_thinking: true})}'
)"

input="$(cat)"

if [[ -z "$input" ]]; then
  die "attachment-minter: empty input on stdin"
  exit 1
fi

system_prompt="$(prompt:load attachment-minter/system)"
user_msg="$(printf '%s' "$input")"

messages="$(
  jq -c -n \
    --arg s "$system_prompt" \
    --arg u "$user_msg" \
    '[{role:"system",content:$s},{role:"user",content:$u}]'
)"

raw="$(
  chat:completion "$MINTER_MODEL" "$messages" "$MINTER_EXTRAS" |
    chat:extract-content
)"

# Strip code fences the model sometimes wraps output in.
raw="$(printf '%s' "$raw" | sed -e 's/^```json//' -e 's/^```//' -e 's/```$//')"

# Validate + normalize. Off-vocab affect or malformed JSON → confirm:false.
valid_affect='["wary","curious","confident","uneasy","resigned","eager","uncertain","surprised"]'

if parsed="$(
  jq -c --argjson vocab "$valid_affect" '
    if (.confirm // false) == true then
      if ([.affect] - $vocab) == [] and (.affect // "") != ""
      then
        {
          confirm: true,
          prediction: (.prediction // ""),
          inner_voice: (.inner_voice // ""),
          affect: .affect,
          confidence: ((.confidence // 0.5) | tonumber | (if . < 0 then 0.0 elif . > 1 then 1.0 else . end))
        }
      else
        {confirm: false}
      end
    else
      {confirm: false}
    end
  ' <<< "$raw" 2>/dev/null)"; then
  printf '%s\n' "$parsed"
else
  printf '{"confirm":false}\n'
fi
