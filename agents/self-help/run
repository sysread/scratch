#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# self-help agent
#
# Answers questions about scratch by reading its own user guides via the
# self-docs tool. Uses agent:simple-completion which delegates to
# agent:complete (pre-fill + profile + tools from spec.json).
#
# stdin:  the user's question
# stdout: the answer (markdown)
#-------------------------------------------------------------------------------

set -euo pipefail

# shellcheck source=/dev/null
source "$SCRATCH_HOME/lib/agent.sh"

agent:simple-completion self-help "$(cat)"
