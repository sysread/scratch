#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# self-help agent
#
# Answers questions about scratch by reading its own user guides via the
# self-docs tool. Uses agent:simple-completion with tool access so the
# model can list and read guides as needed to answer the question.
#
# stdin:  the user's question
# stdout: the answer (markdown)
#-------------------------------------------------------------------------------

set -euo pipefail

# shellcheck source=/dev/null
source "$SCRATCH_HOME/lib/agent.sh"

agent:simple-completion fast "self-help/system" '["self-docs"]'
