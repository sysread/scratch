#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# echo agent - availability check + dependency manifest
#
# The echo agent uses agent:simple-completion which transitively pulls in
# venice:curl (curl + jq + bc) and the prompt loader. Declare the leaf
# binaries here so the doctor reports them under agent:echo and so a
# missing dep produces a clear error before the agent runs.
#-------------------------------------------------------------------------------

set -euo pipefail

# shellcheck source=/dev/null
source "$SCRATCH_HOME/lib/base.sh"

has-commands curl jq bc
