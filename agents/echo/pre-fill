#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# echo pre-fill
#
# Prepend the echo system prompt to the messages array.
#-------------------------------------------------------------------------------

set -euo pipefail

# shellcheck source=/dev/null
{
  source "$SCRATCH_HOME/lib/base.sh"
  source "$SCRATCH_HOME/lib/prompt.sh"
}

messages="$(cat)"

has_system="$(jq '.[0].role == "system"' <<<"$messages")"
if [[ "$has_system" == "true" ]]; then
  printf '%s' "$messages"
  exit 0
fi

system_prompt="$(prompt:load echo/system)"
jq -c --arg sys "$system_prompt" \
  '[{role: "system", content: $sys}] + .' \
  <<<"$messages"
