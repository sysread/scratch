#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# echo agent
#
# Reads stdin and asks the model to echo it back, paraphrased and cleaned
# up grammatically. Useful as the first concrete agent and as a smoke
# test for the agent layer end to end.
#
# This is the canonical example of a simple, single-shot agent: load a
# system prompt, pick a profile, hand off. Five lines.
#-------------------------------------------------------------------------------

set -euo pipefail

# shellcheck source=/dev/null
source "$SCRATCH_HOME/lib/agent.sh"

agent:simple-completion fast "echo/system"
