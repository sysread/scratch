#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# scratch project delete - remove a project config (with confirmation)
#-------------------------------------------------------------------------------

set -euo pipefail

_DESC="Remove a project (with confirmation)"

if [[ "${1:-}" == "synopsis" ]]; then
  printf '%s\n' "$_DESC"
  exit 0
fi

SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT" ]]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" > /dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SCRIPT")"
  [[ "$TARGET" != /* ]] && TARGET="$DIR/$TARGET"
  SCRIPT="$TARGET"
done
SCRIPTDIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

# shellcheck source-path=SCRIPTDIR/../lib
# shellcheck disable=SC1091
{
  source "$SCRIPTDIR/../lib/base.sh"
  source "$SCRIPTDIR/../lib/termio.sh"
  source "$SCRIPTDIR/../lib/tui.sh"
  source "$SCRIPTDIR/../lib/cmd.sh"
  source "$SCRIPTDIR/../lib/project.sh"
}

has-min-bash-version 5

cmd:define "project delete" "$_DESC"
cmd:parse "$@"

#-------------------------------------------------------------------------------
# Main
#-------------------------------------------------------------------------------
main() {
  local arg=""
  local name

  while IFS= read -r arg; do
    break
  done < <(cmd:rest || true)

  project:resolve-name name "$arg"

  project:exists "$name" || die "project not found: $name"

  if ! gum confirm "Delete project '$name'?"; then
    tui:info "Cancelled"
    return 0
  fi

  project:delete "$name"
  gum format -- "Deleted project **${name}**"
}

main
