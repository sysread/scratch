#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# scratch intuit - run the intuition agent against a prompt
#
# Takes a prompt as positional args (or reads stdin if no args are given)
# and pipes it through agents/intuition. The intuition agent returns a
# synthesized first-person directive based on its 4-drive subconscious
# reaction to the input. Useful as a sanity gauge during development and
# as a wrapper for the operator's day-to-day "what does my subconscious
# think about this?" itch.
#
# Set SCRATCH_DEBUG_INTUITION=1 to see each phase's intermediate output
# on stderr (perception, drive:<name>, synthesis).
#
# Examples:
#   scratch intuit "what should I work on next?"
#   git log --oneline -20 | scratch intuit
#   SCRATCH_DEBUG_INTUITION=1 scratch intuit "is REST or GraphQL right here?"
#-------------------------------------------------------------------------------

set -euo pipefail

_DESC="Run the intuition agent against a prompt (positional or stdin)"

if [[ "${1:-}" == "synopsis" ]]; then
  printf '%s\n' "$_DESC"
  exit 0
fi

SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT" ]]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" > /dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SCRIPT")"
  [[ "$TARGET" != /* ]] && TARGET="$DIR/$TARGET"
  SCRIPT="$TARGET"
done
SCRIPTDIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

# shellcheck source-path=SCRIPTDIR/../lib
# shellcheck disable=SC1091
{
  source "$SCRIPTDIR/../lib/base.sh"
  source "$SCRIPTDIR/../lib/cmd.sh"
  source "$SCRIPTDIR/../lib/agent.sh"
}

has-min-bash-version 5

cmd:define "intuit" "$_DESC"
cmd:define-cli-usage "EXAMPLES" "$(
  cat << 'EOF'
scratch intuit "what should I work on next?"
git log --oneline -20 | scratch intuit
SCRATCH_DEBUG_INTUITION=1 scratch intuit "is REST or GraphQL right here?"
EOF
)"
cmd:parse "$@"

#-------------------------------------------------------------------------------
# Main
#-------------------------------------------------------------------------------
main() {
  local -a positionals=()
  local arg
  while IFS= read -r arg; do
    [[ -z "$arg" ]] && continue
    positionals+=("$arg")
  done < <(cmd:rest || true)

  if ((${#positionals[@]} > 0)); then
    # Positional args: join them with spaces and pipe to the agent.
    printf '%s' "${positionals[*]}" | agent:run intuition
  else
    # No positional args: read stdin and pipe through.
    agent:run intuition
  fi
}

main
