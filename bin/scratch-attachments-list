#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# scratch attachments list - human-scannable list of attachments
#
# Orders by (confidence * health) descending — the "active" attachments
# first, stale and weak ones drift toward the bottom. Columns: id, score,
# affect, scope, fires, prediction (truncated).
#
# Examples:
#   scratch attachments list
#   scratch attachments list -p myproject
#-------------------------------------------------------------------------------

set -euo pipefail

_DESC="List attachments for a project, ordered by confidence*health"

if [[ "${1:-}" == "synopsis" ]]; then
  printf '%s\n' "$_DESC"
  exit 0
fi

SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT" ]]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" > /dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SCRIPT")"
  [[ "$TARGET" != /* ]] && TARGET="$DIR/$TARGET"
  SCRIPT="$TARGET"
done
SCRIPTDIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

# shellcheck source-path=SCRIPTDIR/../lib
# shellcheck disable=SC1091
{
  source "$SCRIPTDIR/../lib/base.sh"
  source "$SCRIPTDIR/../lib/cmd.sh"
  source "$SCRIPTDIR/../lib/project.sh"
  source "$SCRIPTDIR/../lib/tui.sh"
  source "$SCRIPTDIR/../lib/attachments.sh"
}

has-min-bash-version 5

cmd:define "attachments list" "$_DESC"
cmd:optional-arg "--project" "-p" "Project name (default: detect from cwd)" "string" ""
cmd:parse "$@"

main() {
  local project_name
  project:resolve-name project_name "$(cmd:get --project)"

  local output
  output="$(attachments:list "$project_name")"

  # attachments:list always prints the header; the body is empty if there
  # are no rows. Detect that case and emit a friendly message instead of
  # a header-only table.
  local body_lines
  body_lines="$(printf '%s\n' "$output" | tail -n +2 | grep -c '.' || true)"
  if [[ "$body_lines" -eq 0 ]]; then
    tui:info "no attachments" project "$project_name"
    return 0
  fi

  printf '%s\n' "$output" | column -t -s $'\t'
}

main
