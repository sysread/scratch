#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# scratch help - browse guides or ask questions about scratch
#
# Two modes:
#   scratch help                        prompt for a question (gum write)
#   scratch help -q "how do I index?"   ask directly via flag
#
# Both modes pipe the question to the self-help agent, which uses the
# self-docs tool to read scratch's guides and answer. The response is
# shown with a spinner while the agent works, then rendered with gum
# format.
#
# For subcommand-specific help, use --help directly on the command
# (e.g., `scratch search --help`).
#-------------------------------------------------------------------------------

set -euo pipefail

_DESC="Browse guides or ask questions about scratch"

if [[ "${1:-}" == "synopsis" ]]; then
  printf '%s\n' "$_DESC"
  exit 0
fi

SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT" ]]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" > /dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SCRIPT")"
  [[ "$TARGET" != /* ]] && TARGET="$DIR/$TARGET"
  SCRIPT="$TARGET"
done
SCRIPTDIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

# shellcheck source-path=SCRIPTDIR/../lib
# shellcheck disable=SC1091
{
  source "$SCRIPTDIR/../lib/base.sh"
  source "$SCRIPTDIR/../lib/cmd.sh"
  source "$SCRIPTDIR/../lib/tui.sh"
  source "$SCRIPTDIR/../lib/agent.sh"
}

has-min-bash-version 5

SCRATCH_HOME="$(cd "$SCRIPTDIR/.." && pwd)"
export SCRATCH_HOME

cmd:define "help" "$_DESC"
cmd:optional-arg "--question" "-q" "Ask a question about scratch" "string" ""
cmd:define-cli-usage "EXAMPLES" "$(
  cat << 'EOF'
scratch help                              # prompt for a question interactively
scratch help -q "how do I index files?"   # ask directly
EOF
)"
cmd:parse "$@"

#-------------------------------------------------------------------------------
# Ask the self-help agent
#-------------------------------------------------------------------------------
_help_ask() {
  local question="$1"
  printf '%s' "$question" \
    | tui:with-spinner "Thinking..." agent:run self-help \
    | tui:format
}

#-------------------------------------------------------------------------------
# Main
#-------------------------------------------------------------------------------
main() {
  local question
  question="$(cmd:get --question)"

  if [[ -n "$question" ]]; then
    _help_ask "$question"
  else
    if ! tui:write question "What do you need help with?" "e.g., how do I index my project?"; then
      return 0
    fi

    [[ -n "$question" ]] || return 0

    _help_ask "$question"
  fi
}

main
