#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# Environment health check
#
# Scans all scratch subcommands and libraries for their declared dependencies
# and reports the status of each one. Unlike helpers/setup --check (which is a
# silent pass/fail gate at startup), doctor produces a human-readable checklist
# for diagnosing environment issues.
#
# Three categories are checked:
#
#   1. External commands - everything declared via has-commands in bin/ and lib/.
#      Each entry shows which subcommands depend on it.
#
#   2. Environment variables - the default output shows a one-line
#      summary (count declared, count set). Pass --env for the full
#      listing: one stanza per var with purpose and subcommand reach.
#      Required vars (require-env-vars) that are unset cause a failure;
#      optional vars (uses-env-vars, uses-secret-env-vars) are
#      informational. Secret values are masked; long config values are
#      truncated.
#
#   3. Developer tools (--dev) - mise-managed tools and other dev deps.
#
# Design constraint: doctor must work even when deps are broken (it is most
# useful precisely then). It cannot depend on gum, tui, or any tool that might
# itself be missing. Output is plain ANSI via raw printf.
#
# Exit codes:
#   0  All checks passed
#   1  One or more checks failed
#-------------------------------------------------------------------------------

set -euo pipefail

#-------------------------------------------------------------------------------
# Script environment
#-------------------------------------------------------------------------------
SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT" ]]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" > /dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SCRIPT")"
  [[ "$TARGET" != /* ]] && TARGET="$DIR/$TARGET"
  SCRIPT="$TARGET"
done
SCRIPTDIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

# shellcheck source-path=SCRIPTDIR/../lib
# shellcheck disable=SC1091
source "$SCRIPTDIR/../lib/base.sh"

has-min-bash-version 5

#-------------------------------------------------------------------------------
# Arg parsing - doctor does its own since it cannot depend on a command
# framework that might require missing tools.
#-------------------------------------------------------------------------------
_DOCTOR_DESC="Check the runtime environment for missing dependencies and required env vars"

FIX=false
DEV=false
ENV=false

for arg in "$@"; do
  case "$arg" in
    synopsis)
      printf '%s\n' "$_DOCTOR_DESC"
      exit 0
      ;;
    --fix) FIX=true ;;
    --dev) DEV=true ;;
    --env) ENV=true ;;
    --help | -h)
      echo "Usage: scratch doctor [--fix] [--dev] [--env]" >&2
      echo "" >&2
      echo "$_DOCTOR_DESC" >&2
      echo "" >&2
      echo "Options:" >&2
      echo "  --fix   Prompt to install missing dependencies via helpers/setup" >&2
      echo "  --dev   Also check developer tools (mise, bats, shellcheck, shfmt)" >&2
      echo "  --env   List every env var scratch reads, with value/purpose/reach" >&2
      exit 0
      ;;
    *)
      warn "scratch doctor: unknown option '$arg'"
      exit 1
      ;;
  esac
done

#-------------------------------------------------------------------------------
# Constants - scanner keywords are held in variables so the literal strings
# never appear in non-comment code lines. This prevents the scanner from
# matching its own grep arguments.
#-------------------------------------------------------------------------------
_KW_HAS_CMD='has-commands'
_KW_REQ_ENV='require-env-vars'
_KW_USES_ENV='uses-env-vars'
_KW_USES_SECRET_ENV='uses-secret-env-vars'
_KW_DESC_ENV='describe-env-var'

#-------------------------------------------------------------------------------
# Globals
#
# _CMD_ENVS              var -> space-sep attribution labels (lib, <verb>,
#                        tool:<name>, etc.) — what scanned the declaration
# _CMD_ENV_REQUIRED      var -> 1 if declared via require-env-vars
# _CMD_ENV_SECRET        var -> 1 if declared via uses-secret-env-vars
# _CMD_ENV_DESCRIPTIONS  var -> pipe-sep descriptions (deduped)
# _CMD_ENV_DECL_FILES    var -> pipe-sep absolute paths where declared;
#                        drives subcommand-closure resolution at display
#-------------------------------------------------------------------------------
declare -A _CMD_DEPS=()
declare -A _CMD_ENVS=()
declare -A _CMD_ENV_REQUIRED=()
declare -A _CMD_ENV_SECRET=()
declare -A _CMD_ENV_DESCRIPTIONS=()
declare -A _CMD_ENV_DECL_FILES=()
_FAILED=false

#-------------------------------------------------------------------------------
# Source-import graph (populated in scan-all-deps, consumed at display)
#
# _LIB_FILES         array of lib relative paths (e.g. "base.sh",
#                    "approvals/project.sh") - the canonical set doctor
#                    attributes transitive reach to
# _FILE_SOURCES      abs file -> space-sep lib rel paths it sources
# _LIB_SUBCOMMANDS   lib rel path -> space-sep subcommand verbs whose
#                    closure (bin/scratch-* -> libs -> libs) reaches it
# _ALL_SUBCOMMANDS   sorted space-sep list of every bin/scratch-* verb;
#                    used to detect "this var reaches every subcommand"
#                    and collapse the display to "(all)"
#-------------------------------------------------------------------------------
declare -a _LIB_FILES=()
declare -A _FILE_SOURCES=()
declare -A _LIB_SUBCOMMANDS=()
_ALL_SUBCOMMANDS=""

#-------------------------------------------------------------------------------
# ANSI color helpers - suppressed when stdout is not a TTY
#-------------------------------------------------------------------------------
if [[ -t 1 ]]; then
  _GREEN=$'\033[0;32m'
  _RED=$'\033[0;31m'
  _DIM=$'\033[2m'
  _RESET=$'\033[0m'
else
  _GREEN=''
  _RED=''
  _DIM=''
  _RESET=''
fi

#-------------------------------------------------------------------------------
# Print a passing check line
#-------------------------------------------------------------------------------
print-ok() {
  printf "  %s✓%s  %-22s %s\n" "$_GREEN" "$_RESET" "$1" "$2"
}

#-------------------------------------------------------------------------------
# Print a failing check line and set the global failure flag
#-------------------------------------------------------------------------------
print-fail() {
  printf "  %s✗%s  %-22s %s\n" "$_RED" "$_RESET" "$1" "$2"
  _FAILED=true
}

#-------------------------------------------------------------------------------
# Print an informational (skipped) check line
#-------------------------------------------------------------------------------
print-note() {
  printf "  %s  %-22s %s%s\n" "$_DIM" "$1" "$2" "$_RESET"
}

#-------------------------------------------------------------------------------
# Mask a secret value: fixed-width asterisk prefix + last 4 chars. Values
# shorter than 4 chars get asterisks only to avoid leaking most of the value.
#-------------------------------------------------------------------------------
mask-secret() {
  local v="$1"
  if ((${#v} < 4)); then
    printf '**********'
  else
    printf '**********%s' "${v: -4}"
  fi
}

#-------------------------------------------------------------------------------
# Truncate a plaintext value to WIDTH chars (default 22 - matches the
# env var table's value column). Values longer than WIDTH get the last
# three chars replaced with "..." so the column stays aligned.
#-------------------------------------------------------------------------------
truncate-value() {
  local v="$1"
  local w="${2:-22}"
  if ((${#v} > w)); then
    printf '%s...' "${v:0:$((w - 3))}"
  else
    printf '%s' "$v"
  fi
}

#-------------------------------------------------------------------------------
# Extract a short display name from a script path - strips the directory and
# the "scratch-" prefix, leaving just the subcommand name.
#-------------------------------------------------------------------------------
subcommand-name() {
  basename "$1" | sed 's/^scratch-//'
}

#-------------------------------------------------------------------------------
# Record one command in _CMD_DEPS, attributing it to NAME. De-dupes per name.
#-------------------------------------------------------------------------------
_record-cmd() {
  local cmd="$1"
  local name="$2"
  if [[ -z "${_CMD_DEPS[$cmd]+set}" ]]; then
    _CMD_DEPS[$cmd]="$name"
  elif [[ " ${_CMD_DEPS[$cmd]} " != *" $name "* ]]; then
    _CMD_DEPS[$cmd]+=" $name"
  fi
}

#-------------------------------------------------------------------------------
# Scan a single file for dependency declarations (has-commands calls).
# Each command found is attributed to the given display name in _CMD_DEPS.
#-------------------------------------------------------------------------------
scan-commands() {
  local file="$1"
  local name="$2"
  local line
  local cmd

  while IFS= read -r line; do
    line="${line#*"${_KW_HAS_CMD}" }"
    for cmd in $line; do
      _record-cmd "$cmd" "$name"
    done
  done < <(grep -h "${_KW_HAS_CMD} " "$file" 2> /dev/null | grep -v '^[[:space:]]*#')
}

#-------------------------------------------------------------------------------
# Record one env var in _CMD_ENVS, attributing it to NAME. De-dupes per name.
#-------------------------------------------------------------------------------
_record-env() {
  local var="$1"
  local name="$2"
  if [[ -z "${_CMD_ENVS[$var]+set}" ]]; then
    _CMD_ENVS[$var]="$name"
  elif [[ " ${_CMD_ENVS[$var]} " != *" $name "* ]]; then
    _CMD_ENVS[$var]+=" $name"
  fi
}

#-------------------------------------------------------------------------------
# Record the file path where VAR was declared. Paths are pipe-separated
# (spaces would collide with the existing attribution format).
#-------------------------------------------------------------------------------
_record-env-file() {
  local var="$1"
  local file="$2"
  local cur="${_CMD_ENV_DECL_FILES[$var]:-}"
  if [[ "|$cur|" != *"|$file|"* ]]; then
    if [[ -n "$cur" ]]; then
      _CMD_ENV_DECL_FILES[$var]="$cur|$file"
    else
      _CMD_ENV_DECL_FILES[$var]="$file"
    fi
  fi
}

#-------------------------------------------------------------------------------
# Record a description for VAR. Deduped; multiple descriptions join with
# " | " so the table stays on one line per var.
#-------------------------------------------------------------------------------
_record-env-desc() {
  local var="$1"
  local desc="$2"
  local cur="${_CMD_ENV_DESCRIPTIONS[$var]:-}"
  [[ -z "$desc" ]] && return 0
  if [[ -z "$cur" ]]; then
    _CMD_ENV_DESCRIPTIONS[$var]="$desc"
  elif [[ " | $cur | " != *" | $desc | "* ]]; then
    _CMD_ENV_DESCRIPTIONS[$var]="$cur | $desc"
  fi
}

#-------------------------------------------------------------------------------
# Scan a single file for env var declarations across four keywords:
# require-env-vars, uses-env-vars, uses-secret-env-vars, describe-env-var.
# Variables are attributed to NAME in _CMD_ENVS; required/secret flags
# are set in the corresponding arrays; descriptions go in _CMD_ENV_DESCRIPTIONS;
# every hit also records the declaring file in _CMD_ENV_DECL_FILES so
# the display layer can compute transitive subcommand reach.
#-------------------------------------------------------------------------------
scan-envs() {
  local file="$1"
  local name="$2"
  local line
  local var
  local desc

  while IFS= read -r line; do
    line="${line#*"${_KW_REQ_ENV}" }"
    for var in $line; do
      _record-env "$var" "$name"
      _record-env-file "$var" "$file"
      _CMD_ENV_REQUIRED[$var]=1
    done
  done < <(grep -h "${_KW_REQ_ENV} " "$file" 2> /dev/null | grep -v '^[[:space:]]*#')

  while IFS= read -r line; do
    line="${line#*"${_KW_USES_ENV}" }"
    for var in $line; do
      _record-env "$var" "$name"
      _record-env-file "$var" "$file"
    done
  done < <(grep -h "${_KW_USES_ENV} " "$file" 2> /dev/null | grep -v '^[[:space:]]*#' | grep -v "${_KW_USES_SECRET_ENV}")

  while IFS= read -r line; do
    line="${line#*"${_KW_USES_SECRET_ENV}" }"
    for var in $line; do
      _record-env "$var" "$name"
      _record-env-file "$var" "$file"
      _CMD_ENV_SECRET[$var]=1
    done
  done < <(grep -h "${_KW_USES_SECRET_ENV} " "$file" 2> /dev/null | grep -v '^[[:space:]]*#')

  # describe-env-var NAME "one-line purpose" - quoted second arg, parsed
  # with `read` so bash tokenization handles the quoting correctly.
  while IFS= read -r line; do
    line="${line#*"${_KW_DESC_ENV}" }"
    # The remainder is: NAME "description text". Split the first token
    # off with parameter expansion; then strip surrounding quotes from
    # the rest. Single or double quotes both tolerated.
    var="${line%% *}"
    desc="${line#* }"
    desc="${desc#\"}"
    desc="${desc%\"}"
    desc="${desc#\'}"
    desc="${desc%\'}"
    _record-env-desc "$var" "$desc"
  done < <(grep -h "${_KW_DESC_ENV} " "$file" 2> /dev/null | grep -v '^[[:space:]]*#')
}

#-------------------------------------------------------------------------------
# scan-via-source FILE NAME
#
# Source FILE in a controlled subshell with `has-commands` and
# `require-env-vars` overridden as recorders. Captures their args via a
# temp file (subshell can't write back to parent associative arrays
# directly), then attributes them to NAME in _CMD_DEPS / _CMD_ENVS.
#
# Used for is-available files (tools/agents/toolboxes), which by
# contract are pure-declaration scripts safe to source. This eliminates
# the textual-grep coupling that would silently miss declarations
# wrapped, extracted into functions, or interpolated.
#
# Bin/lib/helpers stay on grep (scan-commands / scan-envs) — they have
# side effects beyond declarations and a sourcing approach would risk
# triggering them.
#-------------------------------------------------------------------------------
scan-via-source() {
  local file="$1"
  local name="$2"

  local capture
  capture="$(mktemp)"

  # Source base.sh first (sets _INCLUDED_BASE so the file's own source
  # is a no-op), then override the recording functions, then source the
  # target file. We wrap the whole subshell in `|| true` because the
  # sourced is-available may call `exit 1` (e.g. editing toolbox's
  # SCRATCH_EDIT_MODE policy gate). `exit` terminates the subshell
  # before any inner `|| true` can catch it; without the outer one,
  # scratch-doctor's set -e would trip on the failing subshell and
  # silently abort the whole doctor run. We just need the declared
  # deps — the gate's runtime decision is irrelevant here.
  (
    # shellcheck source=/dev/null
    source "$SCRIPTDIR/../lib/base.sh" 2> /dev/null || true

    # SC2329: these are invoked indirectly via the sourced is-available
    # script. Shellcheck can't see that across the source boundary.
    # shellcheck disable=SC2329
    has-commands() {
      local c
      for c in "$@"; do
        printf 'CMD\t%s\n' "$c" >> "$capture"
      done
    }
    export -f has-commands

    # shellcheck disable=SC2329
    require-env-vars() {
      local v
      for v in "$@"; do
        printf 'REQ_ENV\t%s\n' "$v" >> "$capture"
      done
    }
    export -f require-env-vars

    # shellcheck disable=SC2329
    uses-env-vars() {
      local v
      for v in "$@"; do
        printf 'ENV\t%s\n' "$v" >> "$capture"
      done
    }
    export -f uses-env-vars

    # shellcheck disable=SC2329
    uses-secret-env-vars() {
      local v
      for v in "$@"; do
        printf 'SECRET_ENV\t%s\n' "$v" >> "$capture"
      done
    }
    export -f uses-secret-env-vars

    # shellcheck disable=SC2329
    describe-env-var() {
      # Positional: NAME "description". Emit as a 3-field record; any
      # embedded tabs in the description would corrupt parsing but
      # scratch descriptions are short and tab-free by convention.
      printf 'DESC_ENV\t%s\t%s\n' "$1" "${2:-}" >> "$capture"
    }
    export -f describe-env-var

    # SCRATCH_HOME is commonly referenced from is-available scripts.
    # Provide it so they can resolve sibling library paths.
    export SCRATCH_HOME
    SCRATCH_HOME="$(cd "$SCRIPTDIR/.." && pwd)"

    # shellcheck source=/dev/null
    source "$file" 2> /dev/null || true
  ) || true

  local kind value value2
  while IFS=$'\t' read -r kind value value2; do
    case "$kind" in
      CMD) _record-cmd "$value" "$name" ;;
      REQ_ENV)
        _record-env "$value" "$name"
        _record-env-file "$value" "$file"
        _CMD_ENV_REQUIRED[$value]=1
        ;;
      ENV)
        _record-env "$value" "$name"
        _record-env-file "$value" "$file"
        ;;
      SECRET_ENV)
        _record-env "$value" "$name"
        _record-env-file "$value" "$file"
        _CMD_ENV_SECRET[$value]=1
        ;;
      DESC_ENV) _record-env-desc "$value" "$value2" ;;
    esac
  done < "$capture"

  rm -f "$capture"
}

#-------------------------------------------------------------------------------
# Attribution helpers
#
# Each scan target (bin/lib/helpers/tools/...) attributes its dependencies
# to a different label. These tiny functions take a file path and return
# the attribution string. They're called by _scan-deps-in for every file
# matched by a glob pattern.
#-------------------------------------------------------------------------------

# Lib files are all folded into the synthetic "lib" label. Library deps
# apply transitively to many subcommands; per-file attribution would be
# misleadingly noisy.
_attr-lib() { printf '%s\n' "lib"; }

# Tool is-available scripts are attributed to "tool:<name>" where <name>
# is the parent directory's basename. The tool: prefix disambiguates from
# bin/lib/helper attribution in the doctor output.
_attr-tool() { printf 'tool:%s\n' "$(basename "$(dirname "$1")")"; }

# Agent is-available scripts use the same parent-directory-basename trick
# with an "agent:" prefix. Same double-duty contract as tools: the
# is-available script is both a runtime gate and a dep manifest.
_attr-agent() { printf 'agent:%s\n' "$(basename "$(dirname "$1")")"; }

# Toolbox is-available scripts: same again with a "toolbox:" prefix.
# Most toolboxes are pure policy and won't declare any binaries, so this
# scan target usually finds nothing - but the loop is one line and we
# get cross-attribution for free if a toolbox ever does declare a dep.
_attr-toolbox() { printf 'toolbox:%s\n' "$(basename "$(dirname "$1")")"; }

#-------------------------------------------------------------------------------
# _scan-deps-in PATTERN ATTR_FN NEED_X
#
# Glob PATTERN, filter to regular files (and to executables if NEED_X is
# "x"), then for each match call ATTR_FN with the file path to compute
# the attribution label, and feed the file through scan-commands and
# scan-envs.
#
# PATTERN is intentionally unquoted at expansion time so the shell expands
# the glob. The caller passes a quoted string; we expand it inside.
#
# ATTR_FN is the name of a function (or external command) that takes one
# argument (the file path) and prints the attribution label to stdout.
# Use subcommand-name for bin/scratch-*, _attr-lib for lib/*.sh, basename
# for helpers/*, _attr-tool for tools/*/is-available, etc.
#-------------------------------------------------------------------------------
_scan-deps-in() {
  local pattern="$1"
  local attr_fn="$2"
  local need_x="$3"
  # Optional fourth arg "source" → use scan-via-source instead of grep.
  # Used for is-available files (tools/agents/toolboxes), which by
  # contract are pure-declaration scripts safe to source.
  local mode="${4:-grep}"
  local f
  local n

  # shellcheck disable=SC2086 # PATTERN is intentionally word-split for glob expansion
  for f in $pattern; do
    [[ -f "$f" ]] || continue
    [[ "$need_x" != "x" || -x "$f" ]] || continue
    n="$("$attr_fn" "$f")"
    case "$mode" in
      source)
        scan-via-source "$f" "$n"
        ;;
      *)
        scan-commands "$f" "$n"
        scan-envs "$f" "$n"
        ;;
    esac
  done
}

#-------------------------------------------------------------------------------
# Enumerate lib files as relative paths under lib/ (e.g. "base.sh",
# "approvals/project.sh"). This is the canonical vocabulary for the
# import graph: source-line resolution rewrites arbitrary shell paths
# ($_FOO_SCRIPTDIR/bar.sh, $SCRATCH_HOME/lib/bar.sh, etc.) into one of
# these entries.
#-------------------------------------------------------------------------------
collect-lib-files() {
  local lib_root="$SCRIPTDIR/../lib"
  local f rel
  _LIB_FILES=()
  while IFS= read -r f; do
    rel="${f#"$lib_root"/}"
    _LIB_FILES+=("$rel")
  done < <(find "$lib_root" -type f -name '*.sh' 2> /dev/null)
}

#-------------------------------------------------------------------------------
# Map a source-line path string to a canonical lib rel path, or empty
# if it doesn't resolve to a known lib. Longest-suffix match handles
# the subdir case (approvals/project.sh beats project.sh when the
# source-line path contains the subdir).
#-------------------------------------------------------------------------------
resolve-source() {
  local path_str="$1"
  local best=""
  local lib
  for lib in "${_LIB_FILES[@]}"; do
    if [[ "$path_str" == *"/$lib" || "$path_str" == "$lib" ]]; then
      if ((${#lib} > ${#best})); then
        best="$lib"
      fi
    fi
  done
  printf '%s' "$best"
}

#-------------------------------------------------------------------------------
# Scan a file for `source "..."` lines, resolve each to a canonical lib
# rel path, record the set in _FILE_SOURCES[FILE]. Only matches lines
# where `source` is the first non-whitespace token; comments are skipped
# via grep -v.
#-------------------------------------------------------------------------------
scan-sources-in() {
  local file="$1"
  local line path resolved
  local sources=""
  while IFS= read -r line; do
    if [[ "$line" =~ source[[:space:]]+\"([^\"]+)\" ]]; then
      path="${BASH_REMATCH[1]}"
      resolved="$(resolve-source "$path")"
      if [[ -n "$resolved" && " $sources " != *" $resolved "* ]]; then
        sources+="$resolved "
      fi
    fi
  done < <(grep -E '^[[:space:]]*(source|\.)[[:space:]]+' "$file" 2> /dev/null \
    | grep -v '^[[:space:]]*#')
  _FILE_SOURCES[$file]="$sources"
}

#-------------------------------------------------------------------------------
# BFS from FILE through _FILE_SOURCES, collecting every lib rel path
# reachable transitively. Result written space-separated into the
# variable named by the caller via nameref.
#-------------------------------------------------------------------------------
closure-of() {
  local start="$1"
  local -n _out="$2"
  local -A seen=()
  local queue=("$start")
  local cur s lib_path
  _out=""
  while ((${#queue[@]} > 0)); do
    cur="${queue[0]}"
    queue=("${queue[@]:1}")
    [[ -n "${seen[$cur]:-}" ]] && continue
    seen[$cur]=1
    for s in ${_FILE_SOURCES[$cur]:-}; do
      if [[ " $_out " != *" $s "* ]]; then
        _out+="$s "
      fi
      lib_path="$SCRIPTDIR/../lib/$s"
      if [[ -z "${seen[$lib_path]:-}" ]]; then
        queue+=("$lib_path")
      fi
    done
  done
}

#-------------------------------------------------------------------------------
# For every bin/scratch-* subcommand, compute the transitive set of
# libs it sources, and invert into _LIB_SUBCOMMANDS: lib rel path ->
# space-sep sorted subcommand verbs that reach it. _ALL_SUBCOMMANDS
# captures the full verb list for "(all)" collapse at display time.
#-------------------------------------------------------------------------------
build-subcommand-closures() {
  local subcmd_file subcmd_name closure s cur
  local -a verbs=()

  for subcmd_file in "$SCRIPTDIR"/scratch-*; do
    [[ -f "$subcmd_file" && -x "$subcmd_file" ]] || continue
    subcmd_name="$(subcommand-name "$subcmd_file")"
    verbs+=("$subcmd_name")
    closure-of "$subcmd_file" closure
    for s in $closure; do
      cur="${_LIB_SUBCOMMANDS[$s]:-}"
      if [[ " $cur " != *" $subcmd_name "* ]]; then
        if [[ -n "$cur" ]]; then
          _LIB_SUBCOMMANDS[$s]="$cur $subcmd_name"
        else
          _LIB_SUBCOMMANDS[$s]="$subcmd_name"
        fi
      fi
    done
  done

  # Sort verbs for a stable display order; also cache for "(all)" check.
  _ALL_SUBCOMMANDS="$(printf '%s\n' "${verbs[@]}" | sort | tr '\n' ' ')"
  _ALL_SUBCOMMANDS="${_ALL_SUBCOMMANDS% }"

  # Sort the per-lib subcommand lists too so output is deterministic.
  local lib sorted
  for lib in "${!_LIB_SUBCOMMANDS[@]}"; do
    # shellcheck disable=SC2086 # intentional word-split: value is a space-sep list
    sorted="$(printf '%s\n' ${_LIB_SUBCOMMANDS[$lib]} | sort -u | tr '\n' ' ')"
    _LIB_SUBCOMMANDS[$lib]="${sorted% }"
  done
}

#-------------------------------------------------------------------------------
# Populate the import graph from every file scratch-doctor otherwise
# scans. Called once by scan-all-deps after the env/command scan so it
# sees the same universe of files.
#-------------------------------------------------------------------------------
build-import-graph() {
  local f
  collect-lib-files
  for f in "$SCRIPTDIR"/scratch-*; do
    [[ -f "$f" && -x "$f" ]] || continue
    scan-sources-in "$f"
  done
  for f in "$SCRIPTDIR"/../lib/*.sh "$SCRIPTDIR"/../lib/**/*.sh; do
    [[ -f "$f" ]] || continue
    scan-sources-in "$f"
  done
  build-subcommand-closures
}

#-------------------------------------------------------------------------------
# Walk all scratch dependency declarations across the six scan targets:
#
#   bin/scratch-*              attributed by verb (subcommand-name)
#   lib/*.sh                   folded into "lib"
#   helpers/* and helpers/*/*  attributed by helper basename
#   tools/*/is-available       attributed by tool name with "tool:" prefix
#   agents/*/is-available      attributed by agent name with "agent:" prefix
#   toolboxes/*/is-available   attributed by toolbox name with "toolbox:" prefix
#
# All use the same _scan-deps-in helper - one line per target.
#-------------------------------------------------------------------------------
scan-all-deps() {
  _scan-deps-in "$SCRIPTDIR/scratch-*" subcommand-name x
  _scan-deps-in "$SCRIPTDIR/../lib/*.sh" _attr-lib any
  _scan-deps-in "$SCRIPTDIR/../helpers/*" basename x
  _scan-deps-in "$SCRIPTDIR/../helpers/*/*" basename x
  # is-available files are pure-declaration scripts (per their contract);
  # source them with instrumented has-commands / require-env-vars rather
  # than textual-grep so we can't be fooled by line wrapping, function
  # extraction, or interpolation.
  _scan-deps-in "$SCRIPTDIR/../tools/*/is-available" _attr-tool x source
  _scan-deps-in "$SCRIPTDIR/../agents/*/is-available" _attr-agent x source
  _scan-deps-in "$SCRIPTDIR/../toolboxes/*/is-available" _attr-toolbox x source
  build-import-graph
}

#-------------------------------------------------------------------------------
# Check bash version
#-------------------------------------------------------------------------------
check-bash-version() {
  local cur_bash

  cur_bash="${BASH_VERSINFO[0]}.${BASH_VERSINFO[1]}.${BASH_VERSINFO[2]}"
  if ((BASH_VERSINFO[0] >= 5)); then
    print-ok "bash" "$cur_bash"
  else
    print-fail "bash" "$cur_bash (need 5+) - brew install bash"
  fi
}

#-------------------------------------------------------------------------------
# Check that every command declared via has-commands is available on PATH.
# Sorted output for stability across runs.
#-------------------------------------------------------------------------------
check-commands() {
  local dep
  local users
  local where
  local hint

  if ((${#_CMD_DEPS[@]} == 0)); then
    return
  fi

  mapfile -t _dep_names < <(printf '%s\n' "${!_CMD_DEPS[@]}" | sort)

  for dep in "${_dep_names[@]}"; do
    users="${_CMD_DEPS[$dep]}"

    if command -v "$dep" > /dev/null 2>&1; then
      where="$(command -v "$dep")"
      print-ok "$dep" "${_DIM}${where}${_RESET}  ${_DIM}(${users})${_RESET}"
    else
      case "$dep" in
        gcloud) hint="brew install google-cloud-sdk" ;;
        *) hint="brew install ${dep}" ;;
      esac
      print-fail "$dep" "not found - ${hint}  ${_DIM}(${users})${_RESET}"
    fi
  done
}

#-------------------------------------------------------------------------------
# Resolve a var's declaring-file list to a readable "used by" string.
# Lib declarations expand to the set of bin/scratch-* verbs whose
# transitive source closure reaches them (via _LIB_SUBCOMMANDS); if that
# covers every verb, collapse to "(all)". Non-lib declarations keep
# their existing labels (tool:X, agent:X, toolbox:X, helper basename,
# subcommand verb) - those aren't sourced transitively, so a per-call
# execution trace would be needed to do better.
#-------------------------------------------------------------------------------
resolve-used-by() {
  local var="$1"
  local files="${_CMD_ENV_DECL_FILES[$var]:-}"
  local lib_root="$SCRIPTDIR/../lib"
  local helpers_root="$SCRIPTDIR/../helpers"
  local set=""

  # Split on pipes (paths don't contain pipes in this codebase).
  local old_ifs="$IFS"
  IFS='|'
  # shellcheck disable=SC2206 # intentional split: $files is a pipe-sep list
  local -a paths=($files)
  IFS="$old_ifs"

  local p rel verb base
  for p in "${paths[@]}"; do
    if [[ "$p" == "$lib_root"/* ]]; then
      # Lib file: expand to the transitive subcommand closure.
      rel="${p#"$lib_root"/}"
      for verb in ${_LIB_SUBCOMMANDS[$rel]:-}; do
        if [[ " $set " != *" $verb "* ]]; then
          set+="$verb "
        fi
      done
    elif [[ "$p" == "$SCRIPTDIR"/scratch-* ]]; then
      # Subcommand: just its verb.
      verb="$(subcommand-name "$p")"
      if [[ " $set " != *" $verb "* ]]; then
        set+="$verb "
      fi
    elif [[ "$p" == "$helpers_root"/* ]]; then
      # Helper script (flat or nested): attribute by basename, since
      # helpers aren't sourced by subcommands - they're exec'd.
      base="helper:$(basename "$p")"
      if [[ " $set " != *" $base "* ]]; then
        set+="$base "
      fi
    else
      # tools/*/is-available, agents/*/is-available, toolboxes/*/is-available:
      # attribute by parent dir with type prefix (matches the existing
      # _attr-tool / _attr-agent / _attr-toolbox labels).
      base="$(basename "$(dirname "$p")")"
      case "$p" in
        */tools/*) base="tool:$base" ;;
        */agents/*) base="agent:$base" ;;
        */toolboxes/*) base="toolbox:$base" ;;
      esac
      if [[ " $set " != *" $base "* ]]; then
        set+="$base "
      fi
    fi
  done

  set="${set% }"

  # Sort alphabetically for deterministic output.
  local sorted
  # shellcheck disable=SC2086 # intentional word-split: $set is a space-sep list
  sorted="$(printf '%s\n' $set | sort | tr '\n' ' ')"
  sorted="${sorted% }"

  # If every subcommand is in the set, collapse to "(all)".
  if [[ -n "$sorted" && "$sorted" == "$_ALL_SUBCOMMANDS" ]]; then
    printf '(all)'
    return
  fi

  # Group by scratch's dispatch hierarchy: the first hyphen-separated
  # token is the top-level verb. Families (chats-list, chats-prune, ...)
  # collapse to "chats-*" to keep the column scannable. A solitary verb
  # shows by itself even if its top-level has a hyphen (e.g. file-info).
  local -A groups=()
  local v top
  for v in $sorted; do
    top="${v%%-*}"
    if [[ -z "${groups[$top]:-}" ]]; then
      groups[$top]="$v"
    else
      groups[$top]+=" $v"
    fi
  done

  local group_list=""
  local members count
  for top in "${!groups[@]}"; do
    members="${groups[$top]}"
    # shellcheck disable=SC2086
    count=$(
      set -- $members
      echo $#
    )
    if ((count > 1)); then
      group_list+="${top}-* "
    else
      group_list+="$members "
    fi
  done

  # Sort group labels, then cap display. 5 groups is the sweet spot
  # between "enough signal" and "still fits on a line".
  local -a items
  # shellcheck disable=SC2086 # intentional word-split: group_list is a space-sep list
  read -r -a items <<< "$(printf '%s\n' $group_list | sort | tr '\n' ' ')"
  local n=${#items[@]}
  local joined
  if ((n > 5)); then
    printf '%s, %s, %s, %s, %s (+%d more)' \
      "${items[0]}" "${items[1]}" "${items[2]}" "${items[3]}" "${items[4]}" "$((n - 5))"
  else
    joined="${items[*]}"
    printf '%s' "${joined// /, }"
  fi
}

#-------------------------------------------------------------------------------
# Count declared env vars and how many are currently set. Shared by the
# summary line (default mode) and the full listing (--env mode).
#-------------------------------------------------------------------------------
count-env-vars() {
  local -n _total="$1"
  local -n _set_n="$2"
  local var
  _total=0
  _set_n=0
  for var in "${!_CMD_ENVS[@]}"; do
    _total=$((_total + 1))
    if [[ -n "${!var:-}" ]]; then
      _set_n=$((_set_n + 1))
    fi
  done
}

#-------------------------------------------------------------------------------
# One-line summary shown by default (no --env). Counts declared vs set
# and points the user at --env for details. Keeps the default doctor
# output compact while signaling the feature exists.
#-------------------------------------------------------------------------------
summarize-env-vars() {
  local total set_n
  count-env-vars total set_n
  ((total == 0)) && return
  printf '\n  %senv vars: %d declared, %d set - run with --env for details%s\n' \
    "$_DIM" "$total" "$set_n" "$_RESET"
}

#-------------------------------------------------------------------------------
# Full env var listing: one stanza per var in definition-list form.
#
#   <icon> NAME                  <value or "(not set)">
#       <purpose, if any>
#       used by: <subcommand/label list>
#
# Definition-list beats a table here because purposes and subcommand
# reach both vary wildly in length; wrapping them into columns means
# truncating, and truncation was the point of complaint. Status icons
# mirror the rest of doctor: green ✓ when set, red ✗ when required but
# unset, blank (dim) when optional and unset.
#-------------------------------------------------------------------------------
check-env-vars() {
  local var
  local is_required
  local is_secret
  local val
  local display_val
  local desc
  local used_by
  local icon
  local val_w=60

  if ((${#_CMD_ENVS[@]} == 0)); then
    return
  fi

  mapfile -t _env_names < <(printf '%s\n' "${!_CMD_ENVS[@]}" | sort)

  printf '\nEnvironment variables\n'

  for var in "${_env_names[@]}"; do
    is_required="${_CMD_ENV_REQUIRED[$var]:-}"
    is_secret="${_CMD_ENV_SECRET[$var]:-}"
    val="${!var:-}"
    desc="${_CMD_ENV_DESCRIPTIONS[$var]:-}"
    used_by="$(resolve-used-by "$var")"

    # Choose status icon and rendered value based on set/unset +
    # required/secret flags. Icon column is 3 chars (icon + 2 spaces)
    # regardless of color so name columns align.
    if [[ -n "$val" ]]; then
      icon="${_GREEN}✓${_RESET}"
      if [[ -n "$is_secret" ]]; then
        display_val="$(mask-secret "$val")"
      else
        display_val="$(truncate-value "$val" "$val_w")"
      fi
    elif [[ -n "$is_required" ]]; then
      icon="${_RED}✗${_RESET}"
      display_val="${_DIM}(not set)${_RESET}"
      _FAILED=true
    else
      icon=' '
      display_val="${_DIM}(not set)${_RESET}"
    fi

    printf '\n  %s %s  %s\n' "$icon" "$var" "$display_val"
    if [[ -n "$desc" ]]; then
      printf '      %s%s%s\n' "$_DIM" "$desc" "$_RESET"
    fi
    if [[ -n "$used_by" ]]; then
      printf '      %sused by: %s%s\n' "$_DIM" "$used_by" "$_RESET"
    fi
  done
}

#-------------------------------------------------------------------------------
# Check developer tooling: mise itself, mise-managed tools from .mise.toml
#-------------------------------------------------------------------------------
check-dev-tools() {
  local mise_toml
  local tool
  local where

  printf '\nDeveloper tools\n\n'

  if command -v mise > /dev/null 2>&1; then
    where="$(command -v mise)"
    print-ok "mise" "${_DIM}${where}${_RESET}"
  else
    print-fail "mise" "not found - see https://mise.jdx.dev"
    return
  fi

  mise_toml="$SCRIPTDIR/../.mise.toml"
  if [[ -f "$mise_toml" ]]; then
    while IFS='=' read -r tool _; do
      tool="${tool## }"
      tool="${tool%% }"

      [[ -z "$tool" || "$tool" == \#* || "$tool" == \[* ]] && continue

      if command -v "$tool" > /dev/null 2>&1; then
        where="$(command -v "$tool")"
        print-ok "$tool" "${_DIM}${where}${_RESET}"
      else
        print-fail "$tool" "not found - run: mise install"
      fi
    done < <(sed -n '/^\[tools\]/,/^\[/p' "$mise_toml" | grep -v '^\[')
  fi

  # GNU parallel is a dev dependency not managed by mise (not in its tool
  # registry). Bats uses it for inter-file parallelism (-j).
  if command -v parallel > /dev/null 2>&1; then
    where="$(command -v parallel)"
    print-ok "parallel" "${_DIM}${where}${_RESET}"
  else
    print-fail "parallel" "not found - brew install parallel"
  fi
}

#-------------------------------------------------------------------------------
# Offer to run setup to install missing dependencies
#-------------------------------------------------------------------------------
offer-fix() {
  local answer
  local setup_script
  local setup_label

  if [[ "$DEV" == true ]]; then
    setup_script="$SCRIPTDIR/../helpers/dev-setup"
    setup_label="mise run setup"
  else
    setup_script="$SCRIPTDIR/../helpers/setup"
    setup_label="scratch setup"
  fi

  printf 'Run '\''%s'\'' to install missing dependencies? [y/N] ' "$setup_label"
  read -r answer
  case "$answer" in
    [yY]*)
      "$setup_script"
      ;;
    *)
      printf 'Skipped. Run '\''%s'\'' when ready.\n\n' "$setup_label"
      ;;
  esac
}

#-------------------------------------------------------------------------------
# Print summary, optionally offer --fix, and set exit code
#-------------------------------------------------------------------------------
print-summary() {
  printf '\n'
  printf '%.0s-' {1..50}
  printf '\n'

  if [[ "$_FAILED" == true ]]; then
    printf '%sSome checks failed.%s\n\n' "$_RED" "$_RESET"

    if [[ "$FIX" == true ]]; then
      offer-fix
    else
      printf 'Run '\''scratch doctor --fix'\'' to install missing dependencies.\n\n'
    fi

    exit 1
  else
    printf '%sAll checks passed.%s\n\n' "$_GREEN" "$_RESET"
  fi
}

#-------------------------------------------------------------------------------
# Main
#-------------------------------------------------------------------------------

scan-all-deps

printf '\nscratch doctor\n'
printf '%.0s-' {1..50}
printf '\n\n'
printf 'Runtime\n\n'

check-bash-version
check-commands

if [[ "$ENV" == true ]]; then
  check-env-vars
else
  summarize-env-vars
fi

if [[ "$DEV" == true ]]; then
  check-dev-tools
fi

print-summary
