#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# scratch chat - interactive conversation with an LLM
#
# Starts a new conversation or resumes an existing one. Messages are
# persisted as JSONL and managed by lib/conversations.sh. Each turn is
# processed by the coordinator agent (agents/coordinator/), which wraps
# chat:completion with a system prompt and the balanced model profile.
#
# The user composes messages via gum write. Accelerators (@exit, @quit)
# exit the session. On exit, a resume command is printed so the user can
# pick up where they left off.
#
# Examples:
#   scratch chat                          # new conversation (project from cwd)
#   scratch chat -p myproject             # new conversation in specific project
#   scratch chat -f abc12345              # resume by slug
#   scratch chat -c                       # pick a conversation to resume
#-------------------------------------------------------------------------------

set -euo pipefail

_DESC="Start or resume an interactive conversation"

if [[ "${1:-}" == "synopsis" ]]; then
  printf '%s\n' "$_DESC"
  exit 0
fi

SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT" ]]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" > /dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SCRIPT")"
  [[ "$TARGET" != /* ]] && TARGET="$DIR/$TARGET"
  SCRIPT="$TARGET"
done
SCRIPTDIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

# shellcheck source-path=SCRIPTDIR/../lib
# shellcheck disable=SC1091
{
  source "$SCRIPTDIR/../lib/base.sh"
  source "$SCRIPTDIR/../lib/termio.sh"
  source "$SCRIPTDIR/../lib/tui.sh"
  source "$SCRIPTDIR/../lib/cmd.sh"
  source "$SCRIPTDIR/../lib/project.sh"
  source "$SCRIPTDIR/../lib/conversations.sh"
  source "$SCRIPTDIR/../lib/agent.sh"
  source "$SCRIPTDIR/../lib/signals.sh"
  source "$SCRIPTDIR/../lib/tempfiles.sh"
}

has-min-bash-version 5

SCRATCH_HOME="$(cd -P "$SCRIPTDIR/.." && pwd)"
export SCRATCH_HOME

# shellcheck source-path=SCRIPTDIR/../lib
# shellcheck disable=SC1091
source "$SCRIPTDIR/../lib/venice.sh"

cmd:define "chat" "$_DESC"
cmd:optional-arg "--project" "-p" "Project name (default: detect from cwd)" "string" ""
cmd:optional-arg "--follow" "-f" "Resume conversation by slug" "string" ""
cmd:flag "--continue" "-c" "Pick a conversation to resume"
cmd:parse "$@"

#-------------------------------------------------------------------------------
# Debug file logging
#
# When SCRATCH_DEBUG_CHAT is set, all debug events are written to a log
# file at /tmp/scratch/chat-log-<uuid>.log. The log path is printed on
# exit (including Ctrl-C) via a signal handler.
#-------------------------------------------------------------------------------
_CHAT_DEBUG_LOG=""

# _chat:debug MSG [KEY VALUE ...]
#
# Append a timestamped structured line to the debug log file. No-op when
# debug logging is disabled.
_chat:debug() {
  [[ -n "$_CHAT_DEBUG_LOG" ]] || return 0
  local msg="$1"
  shift

  local ts
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

  printf '%s %s' "$ts" "$msg" >> "$_CHAT_DEBUG_LOG"
  while (($# >= 2)); do
    printf ' %s=%s' "$1" "$2" >> "$_CHAT_DEBUG_LOG"
    shift 2
  done
  printf '\n' >> "$_CHAT_DEBUG_LOG"
}

# _chat:debug-exit-notice
#
# Print the debug log path on exit. Registered as a signal handler.
_chat:debug-exit-notice() {
  [[ -n "$_CHAT_DEBUG_LOG" ]] || return 0
  tui:info "chat debug log" path "$_CHAT_DEBUG_LOG"
}

#-------------------------------------------------------------------------------
# _chat:print-separator
#
# Print a left-aligned horizontal rule to stderr, ~1/3 of terminal width,
# in bright-black (dim). Used between turns to visually break up the
# transcript without being visually loud.
#
# Terminal width is resolved from COLUMNS (set by interactive bash, but
# not always exported to subcommands) with a tput fallback and a final
# default of 80.
#-------------------------------------------------------------------------------
_chat:print-separator() {
  local width
  width="${COLUMNS:-$(tput cols 2> /dev/null || echo 80)}"

  local sep_width=$((width / 3))
  ((sep_width < 10)) && sep_width=10

  # Bash-native line construction: pad an empty string to $sep_width columns
  # with spaces, then substitute all spaces for box-drawing light
  # horizontals (U+2500). Unlike underscores, these sit vertically
  # centered in the cell, so the rule floats in the middle of the line.
  local line
  printf -v line '%*s' "$sep_width" ''
  line="${line// /─}"

  local timestamp
  timestamp="$(date '+%Y-%m-%d %H:%M:%S')"

  printf '\n' >&2
  gum style --foreground 8 "${line} ${timestamp}" >&2
  printf '\n\n' >&2
}

#-------------------------------------------------------------------------------
# _chat:display-message ROLE CONTENT
#
# Render a single message with a role header via tui:format on stderr.
# Assistant messages are followed by a separator (see _chat:print-separator)
# to visually break up turns.
#-------------------------------------------------------------------------------
_chat:display-message() {
  local role="$1"
  local content="$2"

  local header
  case "$role" in
    user) header="You" ;;
    assistant) header="Assistant" ;;
    *) return 0 ;;
  esac

  printf '# %s\n\n%s\n\n' "$header" "$content" | tui:format >&2

  if [[ "$role" == "assistant" ]]; then
    _chat:print-separator
  fi
}

#-------------------------------------------------------------------------------
# _chat:display-history PROJECT SLUG
#
# Replay the conversation history to stderr, rendering user, assistant,
# and tool call messages.
#-------------------------------------------------------------------------------
_chat:display-history() {
  local project="$1"
  local slug="$2"

  local messages
  messages="$(conversation:load-messages "$project" "$slug")"

  [[ -n "$messages" ]] || return 0

  while IFS= read -r line; do
    local role content
    role="$(jq -r '.role' <<< "$line")"
    content="$(jq -r '.content // ""' <<< "$line")"

    case "$role" in
      user | assistant)
        _chat:display-message "$role" "$content"
        ;;
      tool)
        local tool_id
        tool_id="$(jq -r '.tool_call_id // "unknown"' <<< "$line")"
        tui:debug-if SCRATCH_DEBUG_TOOLS "tool result" id "$tool_id" result "$content"
        ;;
    esac
  done <<< "$messages"
}

#-------------------------------------------------------------------------------
# _chat:display-new-messages MESSAGES_JSON START_INDEX
#
# Display messages added to the array during a completion round (tool
# calls and tool results). Walks messages[START_INDEX..] and renders
# each one. Assistant messages with tool_calls show the tool name and
# flattened args. Tool result messages show the result content.
#
# Called after agent:complete returns to show what happened during the
# round. This is the "after-the-fact" display model: the agent runs
# the full round, then the caller displays what changed.
#-------------------------------------------------------------------------------
_chat:display-new-messages() {
  local messages_json="$1"
  local start="$2"

  local count
  count="$(jq 'length' <<< "$messages_json")"

  local i
  for ((i = start; i < count; i++)); do
    local msg
    msg="$(jq -c ".[$i]" <<< "$messages_json")"

    local role
    role="$(jq -r '.role' <<< "$msg")"

    case "$role" in
      assistant)
        # Check for tool_calls on this assistant message
        local tool_calls_arr
        tool_calls_arr="$(jq -c '.tool_calls // []' <<< "$msg")"
        if [[ "$tool_calls_arr" != "[]" ]]; then
          local tc tc_count
          tc_count="$(jq 'length' <<< "$tool_calls_arr")"
          for ((tc = 0; tc < tc_count; tc++)); do
            local call_name call_args
            call_name="$(jq -r ".[$tc].function.name" <<< "$tool_calls_arr")"
            call_args="$(jq -c ".[$tc].function.arguments | (fromjson? // {})" <<< "$tool_calls_arr")"

            # Flatten args into key/value pairs for gum log. "level" is
            # renamed to "lvl" because gum log absorbs it as its own keyword.
            local -a kv_pairs=(tool "$call_name")
            local key display_key val
            while IFS= read -r key; do
              val="$(jq -r --arg k "$key" '.[$k] | tostring' <<< "$call_args")"
              display_key="$key"
              [[ "$key" == "level" ]] && display_key="lvl"
              kv_pairs+=("$display_key" "$val")
            done < <(jq -r 'keys[]' <<< "$call_args" 2> /dev/null)

            tui:debug-if SCRATCH_DEBUG_TOOLS "tool call" "${kv_pairs[@]}"
          done
        fi
        ;;
      tool)
        local tool_id content
        tool_id="$(jq -r '.tool_call_id // "unknown"' <<< "$msg")"
        content="$(jq -r '.content // ""' <<< "$msg")"
        tui:debug-if SCRATCH_DEBUG_TOOLS "tool result" id "$tool_id" result "$content"
        ;;
    esac
  done
}

#-------------------------------------------------------------------------------
# _chat:escape-menu VAR
#
# Show a two-option menu when the user hits escape (or Ctrl-C) in gum
# write. Default selection is "Return to chat" so the common case of
# an accidental escape is a single Enter away from resuming. Cancelling
# the menu itself also returns to chat.
#
# Result is assigned to the caller's VAR via nameref: either "exit" or
# "return". Nameref instead of command substitution is required here
# because gum choose renders its TUI to stderr, and wrapping the call in
# $(...) with 2>/dev/null would silently kill the menu display. With a
# nameref, stderr flows straight to the terminal and the TUI renders.
#-------------------------------------------------------------------------------
_chat:escape-menu() {
  local -n _cem_out="$1"

  local choice
  if choice="$(gum choose \
    --header "What would you like to do?" \
    --selected "Return to chat" \
    "Return to chat" \
    "Exit")"; then
    case "$choice" in
      "Exit") _cem_out="exit" ;;
      *) _cem_out="return" ;;
    esac
  else
    # Cancelled (ESC/Ctrl-C in the menu itself) - second escape means exit
    _cem_out="exit"
  fi

  # Wipe any residue gum choose left behind (including "not submitted"
  # on cancel, or the menu header on completion) before returning to
  # the caller. Same pattern as the post-gum-write clear.
  printf '\r\033[2K\033[1A\r\033[2K\033[1A\r\033[2K' >&2
}

#-------------------------------------------------------------------------------
# _chat:is-accelerator INPUT
#
# Return 0 if the input is a recognized accelerator command.
#-------------------------------------------------------------------------------
_chat:is-accelerator() {
  local input="$1"
  local trimmed
  trimmed="$(sed 's/^[[:space:]]*//;s/[[:space:]]*$//' <<< "$input")"

  case "$trimmed" in
    @exit | @quit) return 0 ;;
    *) return 1 ;;
  esac
}

#-------------------------------------------------------------------------------
# Main
#-------------------------------------------------------------------------------
main() {
  # Fail fast if no API key
  venice:api-key > /dev/null

  tmp:install-traps

  # Set up debug file logging when SCRATCH_DEBUG_CHAT is set. The log path
  # is also exported as SCRATCH_CHAT_DEBUG_LOG so subprocesses (notably the
  # coordinator agent and its chat:completion calls) append to the same file.
  if [[ -n "${SCRATCH_DEBUG_CHAT:-}" ]]; then
    mkdir -p /tmp/scratch
    _CHAT_DEBUG_LOG="/tmp/scratch/chat-log-$(uuidgen | tr '[:upper:]' '[:lower:]').log"
    export SCRATCH_CHAT_DEBUG_LOG="$_CHAT_DEBUG_LOG"
    signal:register EXIT chat-debug-log "_chat:debug-exit-notice"
    _chat:debug "session start"
  fi

  local project_name
  project:resolve-name project_name "$(cmd:get --project)"

  # Resolve the conversation: new, follow, or continue
  local slug=""
  local follow_slug
  cmd:get-into follow_slug "--follow"

  if [[ -n "$follow_slug" ]]; then
    # Resume by slug
    if ! conversation:exists "$project_name" "$follow_slug"; then
      die "conversation not found: ${project_name}/${follow_slug}"
      return 1
    fi
    slug="$follow_slug"
  elif [[ "$(cmd:get --continue)" == "1" ]]; then
    # Pick from existing conversations
    local listing
    listing="$(conversation:list "$project_name")"

    if [[ -z "$listing" ]]; then
      die "no conversations to continue in project: ${project_name}"
      return 1
    fi

    # Build display lines for gum filter. Each line shows the truncated
    # slug, last updated timestamp, round count, and the first user
    # message (truncated to fit the terminal width) so conversations are
    # identifiable at a glance.
    local term_width
    term_width="${COLUMNS:-$(tput cols 2> /dev/null || echo 80)}"

    local display_lines=""
    local -a slugs=()
    while IFS= read -r line; do
      local s u r
      s="$(jq -r '.slug' <<< "$line")"
      r="$(jq -r '.round_count' <<< "$line")"

      # Convert UTC ISO8601 timestamp to local 12-hour time for display
      local raw_ts
      raw_ts="$(jq -r '.updated' <<< "$line")"
      u="$(date -j -f "%Y-%m-%dT%H:%M:%SZ" "$raw_ts" "+%Y-%m-%d %l:%M%p" 2> /dev/null \
        | sed 's/  / /; s/AM/am/; s/PM/pm/' || echo "${raw_ts:0:16}")"
      slugs+=("$s")

      # Extract first user message from the conversation for context
      local preview=""
      local msg_file
      msg_file="$(conversation:chat-dir "$project_name" "$s")/messages.jsonl"
      if [[ -f "$msg_file" ]]; then
        # First line with role=user; collapse whitespace for display
        preview="$(grep -m1 '"role":"user"' "$msg_file" 2> /dev/null \
          | jq -r '.content // ""' 2> /dev/null \
          | tr '\n' ' ' \
          | sed 's/[[:space:]]\{2,\}/ /g')" || true
      fi

      # Prefix is fixed-width metadata; preview fills the remaining space
      local prefix
      prefix="$(printf '%-10s  %s  %dr' "${s:0:8}" "$u" "$r")"
      local prefix_len=${#prefix}
      local avail=$((term_width - prefix_len - 3))

      local display_line
      if [[ -n "$preview" && avail -gt 10 ]]; then
        if ((${#preview} > avail)); then
          preview="${preview:0:$((avail - 3))}..."
        fi
        display_line="${prefix}  ${preview}"
      else
        display_line="$prefix"
      fi

      if [[ -n "$display_lines" ]]; then
        display_lines="${display_lines}"$'\n'"${display_line}"
      else
        display_lines="$display_line"
      fi
    done <<< "$listing"

    local chosen
    if ! tui:choose-one chosen "Select a conversation" "conversation" <<< "$display_lines"; then
      return 0
    fi

    # Extract slug from the chosen display line (first field, may be truncated)
    local chosen_prefix="${chosen%% *}"
    local i
    for i in "${!slugs[@]}"; do
      if [[ "${slugs[$i]:0:8}" == "$chosen_prefix" ]]; then
        slug="${slugs[$i]}"
        break
      fi
    done

    if [[ -z "$slug" ]]; then
      die "could not resolve selected conversation"
      return 1
    fi
  else
    # New conversation. Generate the slug now for display but defer file
    # creation until the user actually sends a message. This avoids
    # littering the project with empty conversations from sessions that
    # opened the chat prompt and immediately quit.
    slug="$(uuidgen | tr '[:upper:]' '[:lower:]')"
    tui:info "new conversation" slug "${slug:0:8}" project "$project_name"
  fi

  # Track whether the conversation has been persisted to disk. Resumed
  # conversations are already saved; new ones are deferred until the
  # user sends their first message.
  local is_saved=0
  if conversation:exists "$project_name" "$slug"; then
    is_saved=1
  fi

  # Export slug so session-scoped approvals work inside tool:invoke
  export SCRATCH_CONVERSATION_SLUG="$slug"

  _chat:debug "conversation resolved" slug "$slug" project "$project_name"

  # Display history if resuming
  if [[ "$is_saved" == "1" ]]; then
    tui:info "resuming" slug "${slug:0:8}" project "$project_name"
    _chat:display-history "$project_name" "$slug"
  fi

  # Session-start separator with timestamp
  _chat:print-separator

  # Interactive loop
  while true; do
    local user_input
    local write_rc=0
    tui:write user_input "${slug:0:8}" "Type your message..." || write_rc=$?

    if ((write_rc == 130)); then
      # Ctrl-C: exit immediately
      printf '\r\033[2K\033[1A\r\033[2K\033[1A\r\033[2K' >&2
      break
    elif ((write_rc != 0)); then
      # Escape: show the escape menu. Wipe "not submitted" noise from
      # gum write before rendering the menu.
      printf '\r\033[2K\033[1A\r\033[2K\033[1A\r\033[2K' >&2

      local escape_action
      _chat:escape-menu escape_action
      if [[ "$escape_action" == "exit" ]]; then
        break
      fi
      continue
    fi

    # Check for accelerators
    if _chat:is-accelerator "$user_input"; then
      break
    fi

    # Skip empty input
    if [[ -z "$user_input" ]]; then
      continue
    fi

    # Persist the conversation on first message if it hasn't been saved yet
    if [[ "$is_saved" == "0" ]]; then
      conversation:create-with-slug "$project_name" "$slug"
      is_saved=1
    fi

    # Begin round tracking
    conversation:begin-round "$project_name" "$slug"
    _chat:debug "round begin" slug "$slug"

    # Save and display user message
    local user_msg
    user_msg="$(conversation:build-message user "$user_input")"
    conversation:append-message "$project_name" "$slug" "$user_msg"
    _chat:debug "message appended" role user size "${#user_input}"
    _chat:display-message user "$user_input"

    # Run the completion round via agent:complete. The agent handles
    # pre-fill (system prompt), model/tool resolution, and the tool-call
    # loop. Messages are modified in place; we diff before/after to
    # display tool calls that happened during the round.
    local messages_array
    messages_array="$(conversation:messages-as-array "$project_name" "$slug")"

    local before_count
    before_count="$(jq 'length' <<< "$messages_array")"

    _chat:debug "round start" slug "$slug"
    local response=""
    agent:complete coordinator messages_array response || break
    _chat:debug "round complete" response_size "${#response}"

    # Display any tool call traffic that happened during the round
    _chat:display-new-messages "$messages_array" "$before_count"

    # Persist: rewrite with the updated array (tool calls + results),
    # then append the final assistant text response.
    local assistant_msg
    assistant_msg="$(conversation:build-message assistant "$response")"

    conversation:rewrite "$project_name" "$slug" "$messages_array"
    conversation:append-message "$project_name" "$slug" "$assistant_msg"
    _chat:debug "message appended" role assistant size "${#response}"
    conversation:end-round "$project_name" "$slug"
    _chat:debug "round end" slug "$slug"

    _chat:display-message assistant "$response"
  done

  # Print resume command on exit, but only if the conversation was saved
  if [[ "$is_saved" == "1" ]]; then
    tui:info "to resume: scratch chat -f ${slug} -p ${project_name}"
  fi
}

main
