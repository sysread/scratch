#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# scratch project - parent dispatcher for project management
#
# This is a parent command with no behavior of its own. It delegates to
# leaf subcommands via dispatch:try:
#
#   scratch project list     -> bin/scratch-project-list
#   scratch project show     -> bin/scratch-project-show
#   scratch project create   -> bin/scratch-project-create
#   scratch project edit     -> bin/scratch-project-edit
#   scratch project delete   -> bin/scratch-project-delete
#
# See docs/dev/architecture.md for the subcommand system design.
#-------------------------------------------------------------------------------

set -euo pipefail

_PROJECT_DESC="Manage project configurations"

# Respond to synopsis BEFORE loading any libraries - dispatch calls this
# frequently to build the top-level help listing and it must stay fast.
if [[ "${1:-}" == "synopsis" ]]; then
  printf '%s\n' "$_PROJECT_DESC"
  exit 0
fi

SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT" ]]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" > /dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SCRIPT")"
  [[ "$TARGET" != /* ]] && TARGET="$DIR/$TARGET"
  SCRIPT="$TARGET"
done
SCRIPTDIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

# shellcheck source-path=SCRIPTDIR/../lib
# shellcheck disable=SC1091
{
  source "$SCRIPTDIR/../lib/base.sh"
  source "$SCRIPTDIR/../lib/termio.sh"
  source "$SCRIPTDIR/../lib/tui.sh"
  source "$SCRIPTDIR/../lib/dispatch.sh"
}

has-min-bash-version 5

#-------------------------------------------------------------------------------
# Main
#-------------------------------------------------------------------------------

# Try to dispatch to a leaf subcommand. Never returns on success.
dispatch:try "scratch-project" "$@" || true

# Fallthrough: no subcommand matched. Print usage.
dispatch:usage "scratch-project" "$_PROJECT_DESC"

case "${1:-}" in
  "" | -h | --help | help) exit 0 ;;
  *) exit 1 ;;
esac
