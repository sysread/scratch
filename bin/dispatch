#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# Subcommand dispatcher
#
# Resolves a subcommand name to its executable in bin/ and runs it. This script
# requires bash 5+ - the entrypoint shim (bin/scratch) guarantees that.
#-------------------------------------------------------------------------------

set -euo pipefail

SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT" ]]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" > /dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SCRIPT")"
  [[ "$TARGET" != /* ]] && TARGET="$DIR/$TARGET"
  SCRIPT="$TARGET"
done
SCRIPTDIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

# shellcheck source-path=SCRIPTDIR/../lib
# shellcheck disable=SC1091
{
  source "$SCRIPTDIR/../lib/base.sh"
  source "$SCRIPTDIR/../lib/termio.sh"
  source "$SCRIPTDIR/../lib/tui.sh"
}

has-min-bash-version 5

#-------------------------------------------------------------------------------
# Functions
#-------------------------------------------------------------------------------

# Extract a subcommand name from a script path
cmd:name() {
  basename "${1:?no argument provided}" \
    | sed 's/^.*scratch-//'
}

# List all built-in subcommand paths
cmd:list() {
  local cmd
  for cmd in "$SCRIPTDIR"/scratch-*; do
    [[ -f "$cmd" && -x "$cmd" ]] || continue
    echo "$cmd"
  done | sort -u
}

# Resolve a subcommand name to its path
cmd:path() {
  local subcommand="$1"
  local bin="scratch-$subcommand"

  [[ -z "$subcommand" ]] && usage "no subcommand specified"
  [[ ! -x "$SCRIPTDIR/$bin" ]] && usage "unknown subcommand: $subcommand"
  printf '%s\n' "$SCRIPTDIR/$bin"
}

# Show help for a specific subcommand
cmd:help() {
  local subcommand="${1:-}"
  local cmd
  [[ -z "$subcommand" ]] && usage
  cmd="$(cmd:path "$subcommand")"
  "$cmd" --help
}

# Execute a subcommand
cmd:exec() {
  local subcommand="$1"
  local cmd
  cmd="$(cmd:path "$subcommand")"
  exec "$cmd" "${@:2}"
}

# shellcheck disable=SC2016
usage() {
  local msg="${1:-}"
  local cmd
  local name

  {
    printf '
# USAGE
`scratch <command> [options]`

# SYNOPSIS
AI-powered project research and coding tool.

# OPTIONS
- `-h | --help`\tShow this help message and exit

# SUBCOMMANDS
'
    for cmd in $(cmd:list); do
      name="$(cmd:name "$cmd")"
      printf '\- `%s`\t%s\n' "$name" "$("$cmd" synopsis)"
    done
  } | tui:format >&2

  [[ -n "$msg" ]] && die "$msg"
  exit 0
}

#-------------------------------------------------------------------------------
# Process ARGV
#-------------------------------------------------------------------------------
if (($# == 0)); then
  usage
fi

while (("$#")); do
  case "$1" in
    --)
      shift
      break
      ;;

    help)
      cmd:help "${2:-}"
      shift
      break
      ;;

    -h | --help)
      usage
      ;;

    *)
      cmd:exec "$1" "${@:2}"
      ;;
  esac

  shift
done

exit 0
