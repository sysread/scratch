#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# scratch index - build or update the project file index
#
# Orchestrates a streaming pipeline of independent helpers:
#
#   helpers/index/produce    → walk files, SHA diff, emit work items
#   helpers/index/summarize  → parallel summary agents, upsert to SQLite
#   embed:pool               → JSONL embedding via Elixir pool
#   helpers/index/consume    → update SQLite with embeddings
#
# Each stage is a standalone script reading JSONL from stdin and writing
# JSONL to stdout. This makes each piece independently runnable and
# testable.
#
# Examples:
#   scratch index                  # index current project (detected from cwd)
#   scratch index -p myproject     # index a specific project
#-------------------------------------------------------------------------------

set -euo pipefail

_DESC="Build or update the project file index"

if [[ "${1:-}" == "synopsis" ]]; then
  printf '%s\n' "$_DESC"
  exit 0
fi

SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT" ]]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" > /dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SCRIPT")"
  [[ "$TARGET" != /* ]] && TARGET="$DIR/$TARGET"
  SCRIPT="$TARGET"
done
SCRIPTDIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

# shellcheck source-path=SCRIPTDIR/../lib
# shellcheck disable=SC1091
{
  source "$SCRIPTDIR/../lib/base.sh"
  source "$SCRIPTDIR/../lib/cmd.sh"
  source "$SCRIPTDIR/../lib/project.sh"
  source "$SCRIPTDIR/../lib/index.sh"
  source "$SCRIPTDIR/../lib/embed.sh"
  source "$SCRIPTDIR/../lib/tui.sh"
}

has-min-bash-version 5

SCRATCH_HOME="$(cd "$SCRIPTDIR/.." && pwd)"
export SCRATCH_HOME

# Clean up the entire process group on interrupt
_index_cleanup() {
  trap '' INT TERM
  kill 0 2> /dev/null
  wait 2> /dev/null
}
trap '_index_cleanup; exit 130' INT
trap '_index_cleanup; exit 143' TERM

cmd:define "index" "$_DESC"
cmd:optional-arg "--project" "-p" "Project name (default: detect from cwd)" "string" ""
cmd:parse "$@"

main() {
  local project_name
  project:resolve-name project_name "$(cmd:get --project)"

  local proj_root proj_is_git proj_exclude
  project:load "$project_name" proj_root proj_is_git proj_exclude

  tui:info "indexing" project "$project_name" root "$proj_root"
  index:ensure "$project_name"

  local summary_workers="${SCRATCH_INDEX_PARALLEL_JOBS:-4}"
  local embed_workers="${SCRATCH_INDEX_EMBED_WORKERS:-8}"

  tui:info "pipeline" summary_workers "$summary_workers" embed_workers "$embed_workers"

  local start_time
  start_time="$(date +%s)"

  local helpers="$SCRIPTDIR/../helpers/index"

  "$helpers/produce" "$project_name" "$proj_root" "$proj_is_git" "$proj_exclude" \
    | "$helpers/summarize" "$summary_workers" "$project_name" \
    | embed:pool "$embed_workers" \
    | "$helpers/consume" "$project_name"

  local end_time elapsed
  end_time="$(date +%s)"
  elapsed=$((end_time - start_time))

  index:set-meta "$project_name" "last_indexed_at" "$(date -u +%Y-%m-%dT%H:%M:%S)"

  tui:info "index complete" elapsed "${elapsed}s"
}

main
