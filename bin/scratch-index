#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# scratch index - build or update the project file index
#
# Orchestrates a streaming pipeline of independent helpers:
#
#   helpers/index/produce    → walk files, SHA diff, emit work items
#   helpers/index/summarize  → parallel summary agents, upsert to SQLite
#   embed:pool               → JSONL embedding via Elixir pool
#   helpers/index/consume    → update SQLite with embeddings
#
# Each stage is a standalone script reading JSONL from stdin and writing
# JSONL to stdout. This makes each piece independently runnable and
# testable.
#
# Examples:
#   scratch index                  # index current project (detected from cwd)
#   scratch index -p myproject     # index a specific project
#-------------------------------------------------------------------------------

set -euo pipefail

_DESC="Build or update the project file index"

if [[ "${1:-}" == "synopsis" ]]; then
  printf '%s\n' "$_DESC"
  exit 0
fi

SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT" ]]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" > /dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SCRIPT")"
  [[ "$TARGET" != /* ]] && TARGET="$DIR/$TARGET"
  SCRIPT="$TARGET"
done
SCRIPTDIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

# shellcheck source-path=SCRIPTDIR/../lib
# shellcheck disable=SC1091
{
  source "$SCRIPTDIR/../lib/base.sh"
  source "$SCRIPTDIR/../lib/cmd.sh"
  source "$SCRIPTDIR/../lib/project.sh"
  source "$SCRIPTDIR/../lib/index.sh"
  source "$SCRIPTDIR/../lib/embed.sh"
  source "$SCRIPTDIR/../lib/tui.sh"
  source "$SCRIPTDIR/../lib/signals.sh"
  source "$SCRIPTDIR/../lib/tempfiles.sh"
}

has-min-bash-version 5

SCRATCH_HOME="$(cd -P "$SCRIPTDIR/.." && pwd)"
export SCRATCH_HOME

# shellcheck source-path=SCRIPTDIR/../lib
# shellcheck disable=SC1091
source "$SCRIPTDIR/../lib/venice.sh"

# Clean up the entire process group on interrupt. The signal registry
# handles exit codes (130 for INT, 143 for TERM) after the handler
# returns, and EXIT handlers (including tmp:cleanup) fire after that.
_index_cleanup() {
  trap '' INT TERM
  kill 0 2> /dev/null
  wait 2> /dev/null
}
signal:register INT index-pipeline "_index_cleanup"
signal:register TERM index-pipeline "_index_cleanup"
tmp:install-traps

cmd:define "index" "$_DESC"
cmd:optional-arg "--project" "-p" "Project name (default: detect from cwd)" "string" ""
cmd:parse "$@"

main() {
  # Fail fast if no API key — the summarize stage calls the Venice API
  # and a missing key would silently kill every worker, producing an
  # empty pipeline that exits with SIGPIPE and no explanation.
  venice:api-key > /dev/null

  local project_name
  project:resolve-name project_name "$(cmd:get --project)"

  local proj_root proj_is_git proj_exclude
  project:load "$project_name" proj_root proj_is_git proj_exclude

  tui:info "indexing" project "$project_name" root "$proj_root"
  index:ensure "$project_name"

  local summary_workers="${SCRATCH_INDEX_PARALLEL_JOBS:-8}"
  local embed_workers="${SCRATCH_INDEX_EMBED_WORKERS:-4}"

  tui:info "pipeline" summary_workers "$summary_workers" embed_workers "$embed_workers"

  local start_time
  start_time="$(date +%s)"

  local helpers="$SCRIPTDIR/../helpers/index"
  local working="$SCRATCH_HOME/libexec/working.exs"

  # Totals shown in the progress bar are upper bounds computed with cheap
  # commands — the actual work done can be less (items already indexed get
  # skipped by the producers). The bar may finish below 100%, which is OK;
  # the spinner + recent list carry the main UX.
  local files_total commits_total chats_total
  if [[ "$proj_is_git" == "true" ]]; then
    files_total="$(git -C "$proj_root" ls-files 2> /dev/null | wc -l | tr -d ' ')"
    commits_total="$(git -C "$proj_root" rev-list --count HEAD 2> /dev/null || echo 0)"
  else
    files_total="$(find "$proj_root" -type f 2> /dev/null | wc -l | tr -d ' ')"
    commits_total=0
  fi
  [[ "$files_total" -gt 0 ]] || files_total=1

  local chats_dir="${SCRATCH_PROJECTS_DIR}/${project_name}/chats"
  if [[ -d "$chats_dir" ]]; then
    chats_total="$(find "$chats_dir" -mindepth 1 -maxdepth 1 -type d 2> /dev/null | wc -l | tr -d ' ')"
  else
    chats_total=0
  fi

  # Each phase runs its full producer → summarize → embed → consume pipeline
  # inside a subshell whose stderr is merged with stdout (2>&1) and piped
  # through libexec/working.exs. Consume's stdout emits "ok <type>/<id>"
  # per finalized entry, which working.exs matches to advance the progress
  # bar and fill the recent list. All tui:* log output from the stages
  # flows through the same pipe and scrolls above the live region.

  _index_files() {
    (
      "$helpers/produce" "$project_name" "$proj_root" "$proj_is_git" "$proj_exclude" \
        | "$helpers/summarize" "$project_name" "$summary_workers" \
        | embed:pool "$embed_workers" \
        | "$helpers/consume" "$project_name"
    ) 2>&1 \
      | elixir "$working" \
        --total "$files_total" \
        --match '^ok ' \
        --extract '^ok (.+)' \
        --label 'Indexing files'
  }

  _index_commits() {
    (
      "$helpers/produce-commits" "$project_name" "$proj_root" \
        | "$helpers/summarize" "$project_name" "$summary_workers" \
        | embed:pool "$embed_workers" \
        | "$helpers/consume" "$project_name"
    ) 2>&1 \
      | elixir "$working" \
        --total "$commits_total" \
        --match '^ok ' \
        --extract '^ok (.+)' \
        --label 'Indexing commits'
  }

  _index_chats() {
    (
      "$helpers/produce-conversations" "$project_name" \
        | "$helpers/summarize" "$project_name" "$summary_workers" \
        | embed:pool "$embed_workers" \
        | "$helpers/consume" "$project_name"
    ) 2>&1 \
      | elixir "$working" \
        --total "$chats_total" \
        --match '^ok ' \
        --extract '^ok (.+)' \
        --label 'Indexing chats'
  }

  _index_files

  if [[ "$proj_is_git" == "true" && "$commits_total" -gt 0 ]]; then
    _index_commits
  fi

  if [[ -d "$chats_dir" && "$chats_total" -gt 0 ]]; then
    _index_chats
  fi

  local end_time elapsed
  end_time="$(date +%s)"
  elapsed=$((end_time - start_time))

  index:set-meta "$project_name" "last_indexed_at" "$(date -u +%Y-%m-%dT%H:%M:%S)"

  tui:info "index complete" elapsed "${elapsed}s"
}

main
