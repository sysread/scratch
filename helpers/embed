#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# Embedding generator wrapper
#
# Delegates to libexec/embed.exs with the correct compiler flags. Apple clang 17+
# promotes a C++ template warning to an error that breaks EXLA's NIF
# compilation. The CXX override suppresses that specific error.
#
# Usage:
#   helpers/embed <file>       # embed the contents of a file
#   echo "some text" | helpers/embed -   # embed from stdin
#-------------------------------------------------------------------------------

set -euo pipefail

SCRIPT="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT" ]]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" > /dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SCRIPT")"
  [[ "$TARGET" != /* ]] && TARGET="$DIR/$TARGET"
  SCRIPT="$TARGET"
done
SCRIPTDIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

# shellcheck source-path=SCRIPTDIR/../lib
# shellcheck disable=SC1091
source "$SCRIPTDIR/../lib/base.sh"

# Fail fast with a helpful install hint if elixir is missing. Also gives
# scratch-doctor a has-commands declaration to discover and report under
# the "embed" attribution.
has-commands elixir

# Apple clang 17+ treats -Wmissing-template-arg-list-after-template-kw as
# an error, which breaks EXLA's XLA header compilation. This only matters
# on the first run when the NIF is compiled; subsequent runs use the cache.
export CXX="${CXX:-c++} -Wno-error=missing-template-arg-list-after-template-kw"

exec elixir "$SCRIPTDIR/../libexec/embed.exs" "$@"
