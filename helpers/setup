#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# Runtime environment setup
#
# This script must remain compatible with bash 3.2 (macOS system default)
# since its job includes installing bash 5+ when needed.
#
# Usage:
#   helpers/setup          # install all runtime dependencies
#   helpers/setup --check  # exit 0 if all deps present, 1 with warnings if not
#
# IMPORTANT: Do not use ANY bash 4+ features in this file.
#-------------------------------------------------------------------------------

set -euo pipefail

SCRIPT="${BASH_SOURCE[0]}"
while [ -L "$SCRIPT" ]; do
  DIR="$(cd -P "$(dirname "$SCRIPT")" > /dev/null 2>&1 && pwd)"
  TARGET="$(readlink "$SCRIPT")"
  case "$TARGET" in
    /*) ;;
    *) TARGET="$DIR/$TARGET" ;;
  esac
  SCRIPT="$TARGET"
done
# shellcheck disable=SC2034 # SCRIPTDIR will be used by dev-setup delegation
SCRIPTDIR="$(cd -P "$(dirname "$SCRIPT")" && pwd)"

#-------------------------------------------------------------------------------
# Runtime dependencies - the commands scratch needs at runtime.
# Keep this list in sync with what subcommands declare via has-commands.
#-------------------------------------------------------------------------------
RUNTIME_DEPS="bash jq gum curl elixir"

#-------------------------------------------------------------------------------
# Map a command name to its brew formula when they differ
#-------------------------------------------------------------------------------
brew_formula_for() {
  case "$1" in
    *) echo "$1" ;;
  esac
}

#-------------------------------------------------------------------------------
# Map a command name to its apt package when they differ
#-------------------------------------------------------------------------------
apt_package_for() {
  case "$1" in
    *) echo "$1" ;;
  esac
}

#-------------------------------------------------------------------------------
# Scan for missing runtime deps
#-------------------------------------------------------------------------------
find_missing() {
  local missing=""
  for dep in $RUNTIME_DEPS; do
    if ! command -v "$dep" > /dev/null 2>&1; then
      missing="$missing $dep"
    fi
  done
  echo "$missing"
}

#-------------------------------------------------------------------------------
# --check mode: report missing deps and exit
#-------------------------------------------------------------------------------
if [ "${1:-}" = "--check" ]; then
  missing="$(find_missing)"
  if [ -z "$missing" ]; then
    exit 0
  fi

  for dep in $missing; do
    echo "WARNING: $dep not found" >&2
  done
  exit 1
fi

#-------------------------------------------------------------------------------
# Install mode
#-------------------------------------------------------------------------------
echo "scratch setup" >&2
echo "" >&2

missing="$(find_missing)"

if [ -z "$missing" ]; then
  echo "All runtime dependencies are installed." >&2
  exit 0
fi

echo "Missing dependencies:$missing" >&2
echo "" >&2

# Detect package manager and install
if command -v brew > /dev/null 2>&1; then
  for dep in $missing; do
    formula="$(brew_formula_for "$dep")"
    echo "Installing $dep via brew..." >&2
    brew install "$formula"
  done
elif command -v apt-get > /dev/null 2>&1; then
  for dep in $missing; do
    pkg="$(apt_package_for "$dep")"
    echo "Installing $dep via apt..." >&2
    sudo apt-get install -y "$pkg"
  done
else
  echo "No supported package manager found (need brew or apt-get)." >&2
  echo "Please install manually:$missing" >&2
  exit 1
fi

echo "" >&2
echo "Setup complete." >&2
