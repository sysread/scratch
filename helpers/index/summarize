#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# index/summarize - summarize files and upsert to index
#
# Reads JSONL from stdin (one work item per line), runs the summary agent
# against each file, upserts the summary into SQLite (with embedding=NULL),
# and writes {id, text} JSONL to stdout for the embed stage.
#
# Parallelism uses wait -n -p (bash 5.1+) to maintain a pool of N workers.
# The read loop blocks when the pool is full (wait -n blocks), which blocks
# the pipe, which backpressures the produce stage. Natural flow control.
#
# Args: PROJECT_NAME [WORKERS]
# stdin:  JSONL {"id":"<relpath>","sha":"<hex>","file":"<abspath>"}
# stdout: JSONL {"id":"<relpath>","text":"<summary text for embedding>"}
#-------------------------------------------------------------------------------

set -euo pipefail

# SCRATCH_HOME must be set by the caller (bin/scratch-index exports it)
# shellcheck disable=SC1091,SC2031
{
  source "${SCRATCH_HOME}/lib/base.sh"
  source "${SCRATCH_HOME}/lib/index.sh"
  source "${SCRATCH_HOME}/lib/agent.sh"
  source "${SCRATCH_HOME}/lib/tui.sh"
}

has-commands jq flock

project="$1"
pool_size="${2:-4}"

lockfile="/tmp/scratch-index-summarize-lock.$$"
counterfile="/tmp/scratch-index-summarize-count.$$"
touch "$lockfile"
printf '0' >"$counterfile"
# shellcheck disable=SC2064
trap "rm -f '$lockfile' '$counterfile'" EXIT

# Process a single work item: summarize, upsert, emit. Runs in a
# background subshell. Stdout writes are serialized with flock so
# concurrent workers don't interleave JSONL lines.
_summarize_one() {
  local ident="$1"
  local sha="$2"
  local file_path="$3"

  tui:debug "summarize" status "starting" file "$ident"

  # Skip empty files
  if [[ ! -s "$file_path" ]]; then
    local empty_summary='{"summary":"Empty, zero-length file.","questions":[]}'
    index:record "$project" file "$ident" "$sha" "$empty_summary"
    tui:debug "summarize" status "skipped" file "$ident" reason "empty / zero-length file"
    return 0
  fi

  # Run the summary agent with stdin redirected from the file so it
  # can't consume lines from the pipeline stdin.
  local summary=""
  if ! summary="$(agent:run summary <"$file_path" 2>&1)"; then
    tui:warn "summarize" status "failed" file "$ident" "error" "$summary"
    return 1
  fi

  # Upsert to SQLite (durable — survives Ctrl-C)
  index:record "$project" file "$ident" "$sha" "$summary"

  # Extract embeddable text from the structured summary
  local embed_text
  embed_text="$(printf '%s' "$summary" | jq -r '
    if .summary then
      .summary + " " + (.questions // [] | join(" "))
    else
      tostring
    end
  ')"

  # Write to stdout under flock so multi-worker writes don't interleave
  local out_json
  out_json="$(jq -c -n --arg id "$ident" --arg text "$embed_text" \
    '{id: $id, text: $text}')"
  flock "$lockfile" printf '%s\n' "$out_json"

  # Progress (stderr, not serialized — interleaved lines are fine for logs)
  tui:info "summarize" status "done" file "$ident"
}

pids=()

while IFS= read -r line; do
  [[ -n "$line" ]] || continue

  ident="$(printf '%s' "$line" | jq -r '.id')"
  sha="$(printf '%s' "$line" | jq -r '.sha')"
  file_path="$(printf '%s' "$line" | jq -r '.file')"

  # If pool is full, block until a slot opens
  if ((${#pids[@]} >= pool_size)); then
    wait -n -p finished_pid "${pids[@]}" || true
    # Prune the finished PID
    new_pids=()
    for pid in "${pids[@]}"; do
      [[ "$pid" != "$finished_pid" ]] && new_pids+=("$pid")
    done
    pids=("${new_pids[@]}")
  fi

  # Dispatch in background
  _summarize_one "$ident" "$sha" "$file_path" &
  pids+=($!)
done

# Drain remaining workers
for pid in "${pids[@]}"; do
  wait "$pid" || true
done
