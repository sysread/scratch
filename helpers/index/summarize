#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# index/summarize - summarize files and upsert to index
#
# Reads JSONL from stdin (one work item per line), runs the summary agent
# against each file, upserts the summary into SQLite (with embedding=NULL),
# and writes {id, text} JSONL to stdout for the embed stage.
#
# Parallelism uses wait -n -p (bash 5.1+) to maintain a pool of N workers.
# The read loop blocks when the pool is full (wait -n blocks), which blocks
# the pipe, which backpressures the produce stage. Natural flow control.
#
# Args: PROJECT_NAME [WORKERS]
# stdin:  JSONL {"id":"<relpath>","sha":"<hex>","file":"<abspath>"}
# stdout: JSONL {"id":"<relpath>","text":"<summary text for embedding>"}
#-------------------------------------------------------------------------------

set -euo pipefail

# SCRATCH_HOME must be set by the caller (bin/scratch-index exports it)
# shellcheck disable=SC1091,SC2031
{
  source "${SCRATCH_HOME}/lib/base.sh"
  source "${SCRATCH_HOME}/lib/index.sh"
  source "${SCRATCH_HOME}/lib/agent.sh"
  source "${SCRATCH_HOME}/lib/tui.sh"
}

has-commands jq flock

project="$1"
pool_size="${2:-4}"

lockfile="/tmp/scratch-index-summarize-lock.$$"
tallyfile="/tmp/scratch-index-summarize-tally.$$"
touch "$lockfile" "$tallyfile"
# shellcheck disable=SC2064
trap "rm -f '$lockfile' '$tallyfile'" EXIT

# Process a single work item: summarize, upsert, emit. Runs in a
# background subshell. Stdout writes are serialized with flock so
# concurrent workers don't interleave JSONL lines.
_summarize_one() {
  local ident="$1"
  local sha="$2"
  local file_path="$3"

  tui:debug-if SCRATCH_DEBUG_INDEX "summarize starting" "file=$ident"

  # Skip empty files
  if [[ ! -s "$file_path" ]]; then
    local empty_summary='{"summary":"Empty, zero-length file.","questions":[]}'
    index:record "$project" file "$ident" "$sha" "$empty_summary"
    tui:debug-if SCRATCH_DEBUG_INDEX "summarize skipped" "file=$ident" "reason=empty file"
    printf 'skip\n' >>"$tallyfile"
    return 0
  fi

  # Run the summary agent with stdin redirected from the file so it
  # can't consume lines from the pipeline stdin.
  #
  # On failure, the existing index entry (if any) is preserved — we
  # only upsert on success. The next `scratch index` run will see the
  # SHA mismatch and retry this file. This makes indexing idempotent:
  # partial failures never corrupt previously-good data.
  local summary=""
  if ! summary="$(agent:run summary <"$file_path" 2>&1)"; then
    tui:warn "summarize failed" "file=$ident" "error=$summary"
    printf 'fail\n' >>"$tallyfile"
    return 1
  fi

  index:update-summary "$project" file "$ident" "$summary"

  # Extract embeddable text from the structured summary
  local embed_text
  embed_text="$(printf '%s' "$summary" | jq -r '
    if .summary then
      .summary + " " + (.questions // [] | join(" "))
    else
      tostring
    end
  ')"

  # Write to stdout under flock so multi-worker writes don't interleave.
  # Include sha so the consume stage can finalize the entry (write the
  # SHA only after embedding succeeds).
  local out_json
  out_json="$(jq -c -n --arg id "$ident" --arg sha "$sha" --arg text "$embed_text" \
    '{id: $id, sha: $sha, text: $text}')"
  flock "$lockfile" printf '%s\n' "$out_json"

  printf 'ok\n' >>"$tallyfile"
  tui:info "summarized" "file=$ident"
}

pids=()

while IFS= read -r line; do
  [[ -n "$line" ]] || continue

  ident="$(printf '%s' "$line" | jq -r '.id')"
  sha="$(printf '%s' "$line" | jq -r '.sha')"
  file_path="$(printf '%s' "$line" | jq -r '.file')"

  # If pool is full, block until a slot opens. The || true is
  # intentional: per-worker failures are tracked via the tally file
  # (each worker appends ok/fail/skip), not via exit codes. Failing
  # the whole pipeline on one bad file would be worse than continuing.
  if ((${#pids[@]} >= pool_size)); then
    wait -n -p finished_pid "${pids[@]}" || true
    # Prune the finished PID
    new_pids=()
    for pid in "${pids[@]}"; do
      [[ "$pid" != "$finished_pid" ]] && new_pids+=("$pid")
    done
    pids=("${new_pids[@]}")
  fi

  # Dispatch in background
  _summarize_one "$ident" "$sha" "$file_path" &
  pids+=($!)
done

# Drain remaining workers. Same || true rationale as above — failures
# are already recorded in the tally file by each worker.
for pid in "${pids[@]}"; do
  wait "$pid" || true
done

# Report tally. grep -c prints "0" AND returns exit code 1 on no
# matches, so || echo 0 would produce "0\n0". Use || true instead
# and let grep's "0" output stand.
ok_count="$(grep -c '^ok$' "$tallyfile" 2>/dev/null || true)"
fail_count="$(grep -c '^fail$' "$tallyfile" 2>/dev/null || true)"
skip_count="$(grep -c '^skip$' "$tallyfile" 2>/dev/null || true)"
tui:info "summarize complete" "ok=${ok_count}" "failed=${fail_count}" "skipped=${skip_count}"
