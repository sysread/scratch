#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# index/consume - finalize index entries with embeddings
#
# Reads JSONL from stdin (embed pool output) and finalizes each entry
# by writing both the embedding AND the content SHA. The SHA is only
# committed here — not in the summarize stage — so that a failed
# embedding leaves the SHA stale, causing produce to re-emit the file
# on the next run. This makes `scratch index` idempotent: partial
# failures never leave an entry in a "SHA current but embedding missing"
# state.
#
# Args: PROJECT_NAME
# stdin: JSONL {"id":"<relpath>","sha":"<hex>","embedding":[...]}
#-------------------------------------------------------------------------------

set -euo pipefail

# SCRATCH_HOME must be set by the caller
# shellcheck source-path=SCRIPTDIR/../../lib
# shellcheck disable=SC1091
{
  source "${SCRATCH_HOME}/lib/base.sh"
  source "${SCRATCH_HOME}/lib/index.sh"
  source "${SCRATCH_HOME}/lib/tui.sh"
}

has-commands jq

project="$1"

# Progress tracking — read the total from the spinner progress file
# (written by produce) and update done count as entries are finalized.
_consume_done=0
_consume_total=0

while IFS= read -r line; do
  [[ -n "$line" ]] || continue

  entry_id="$(printf '%s' "$line" | jq -r '.id')"
  entry_sha="$(printf '%s' "$line" | jq -r '.sha // empty')"
  embed_json="$(printf '%s' "$line" | jq -c '.embedding')"

  tui:debug-if SCRATCH_DEBUG_INDEX "embedding received" "file=$entry_id"

  if [[ -n "$entry_id" && -n "$entry_sha" && -n "$embed_json" && "$embed_json" != "null" ]]; then
    index:finalize "$project" file "$entry_id" "$entry_sha" "$embed_json"
    tui:info "embedded" "file=$entry_id"

    # Update spinner progress file
    if [[ -n "${TUI_PROGRESS_FILE:-}" ]]; then
      _consume_done=$((_consume_done + 1))
      if ((_consume_total == 0)) && [[ -s "$TUI_PROGRESS_FILE" ]]; then
        read -r _ _consume_total < "$TUI_PROGRESS_FILE" 2> /dev/null || true
      fi
      if ((_consume_total > 0)); then
        printf '%d %d\n' "$_consume_done" "$_consume_total" > "$TUI_PROGRESS_FILE"
      fi
    fi
  fi
done
