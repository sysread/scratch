#!/usr/bin/env bash

#-------------------------------------------------------------------------------
# index/consume - finalize index entries with embeddings
#
# Reads JSONL from stdin (embed pool output) and finalizes each entry
# by writing both the embedding AND the content SHA. The SHA is only
# committed here — not in the summarize stage — so that a failed
# embedding leaves the SHA stale, causing produce to re-emit the file
# on the next run. This makes `scratch index` idempotent: partial
# failures never leave an entry in a "SHA current but embedding missing"
# state.
#
# Args: PROJECT_NAME
# stdin: JSONL {"id":"<relpath>","sha":"<hex>","embedding":[...]}
#-------------------------------------------------------------------------------

set -euo pipefail

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  cat << 'EOF'
Usage: helpers/index/consume PROJECT_NAME

Read {id, sha, embedding, type} JSONL from stdin (embed pool output) and
finalize each entry by writing BOTH the embedding AND the content SHA. The
SHA is only committed here, not during summarize — failed embeddings leave
the SHA stale so produce re-emits on the next run. Idempotent.

Arguments:
  PROJECT_NAME  scratch project name

Stdin:  JSONL {"id":..., "sha":..., "embedding":[...], "type":"..."}

Env:
  SCRATCH_HOME          required (exported by bin/scratch-index)
  SCRATCH_DEBUG_INDEX   set for per-item debug output
  TUI_PROGRESS_FILE     optional; progress counter updated as entries finalize
EOF
  exit 0
fi

# SCRATCH_HOME must be set by the caller
# shellcheck source-path=SCRIPTDIR/../../lib
# shellcheck disable=SC1091
{
  source "${SCRATCH_HOME}/lib/base.sh"
  source "${SCRATCH_HOME}/lib/index.sh"
  source "${SCRATCH_HOME}/lib/tui.sh"
}

has-commands jq
uses-env-vars SCRATCH_DEBUG_INDEX
describe-env-var SCRATCH_DEBUG_INDEX "log per-item progress during indexing pipeline stages"

project="$1"

# Progress tracking — read the total from the spinner progress file
# (written by produce) and update done count as entries are finalized.
_consume_done=0
_consume_total=0

while IFS= read -r line; do
  [[ -n "$line" ]] || continue

  entry_id="$(printf '%s' "$line" | jq -r '.id')"
  entry_sha="$(printf '%s' "$line" | jq -r '.sha // empty')"
  embed_json="$(printf '%s' "$line" | jq -c '.embedding')"
  entry_type="$(printf '%s' "$line" | jq -r '.type // "file"')"

  tui:debug-if SCRATCH_DEBUG_INDEX "embedding received" "$entry_type" "$entry_id"

  if [[ -n "$entry_id" && -n "$entry_sha" && -n "$embed_json" && "$embed_json" != "null" ]]; then
    index:finalize "$project" "$entry_type" "$entry_id" "$entry_sha" "$embed_json"
    tui:debug-if SCRATCH_DEBUG_INDEX "indexed" "$entry_type" "$entry_id"

    # Emit a completion marker on stdout. Consume is the tail of the index
    # pipeline, so its stdout is otherwise unused. libexec/working.exs reads
    # this to advance its progress bar and populate the recent list. The
    # format ("ok <type>/<id>") gives working.exs a clean regex match and a
    # capture group for the displayed name.
    printf 'ok %s/%s\n' "$entry_type" "$entry_id"

    # Legacy spinner progress file — still populated for callers that don't
    # pipe through working.exs.
    if [[ -n "${TUI_PROGRESS_FILE:-}" ]]; then
      _consume_done=$((_consume_done + 1))
      if ((_consume_total == 0)) && [[ -s "$TUI_PROGRESS_FILE" ]]; then
        read -r _ _consume_total < "$TUI_PROGRESS_FILE" 2> /dev/null || true
      fi
      if ((_consume_total > 0)); then
        printf '%d %d\n' "$_consume_done" "$_consume_total" > "$TUI_PROGRESS_FILE"
      fi
    fi
  fi
done
